#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## Orchestrator: run the dist-ai regression/fuzz/e2e/integration suites,
## aggregate PASS / FAIL / SKIP / TIMEOUT, and exit non-zero if any FAILed.
##
## Run 'dist-ai-tests-all --help' for full usage (see usage() below).

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

mydir="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd )"

repo_root=""
component=""
component_root=""
helper_scripts_root=""
skip_suites=()
progress_file=""
run_core="false"
run_fuzz="false"
run_e2e="false"
run_integration="false"
list_only="false"
timeout_core=300
timeout_fuzz=600
timeout_heavy=600

## Suite registries. Each name is an entrypoint in the same bin dir as this
## script. mediawiki-dom-snapshot is a capture tool, not a pass/fail test, so
## it is deliberately excluded.
core_suites=(
   check-ref-commits-for-unicode-tests
   dm-help-steps-tests
   dm-virtualbox-wiki-links-tests
   genmkfile-tests
   git-meld-tests
   grep-find-unicode-wrapper-tests
   lockfile-tests
   msgcollector-tests
   onion-grater-tests
   open-link-confirmation-tests
   privleap-tests
   sanitize-string-tests
   secure-terminal-tests
   sdwdate-gui-tests
   stcat-family-tests
   stdisplay-tests
   systemcheck-tests
   tor-control-panel-tests
   unicode-show-tests
   web-analyzer-tests
   website-tests
)
fuzz_suites=(
   check-ref-commits-for-unicode-tests-fuzz
   git-meld-tests-fuzz
   grep-find-unicode-wrapper-tests-fuzz
   iso-boot-tests-fuzz
   lockfile-tests-fuzz
   msgcollector-tests-fuzz
   privleap-tests-fuzz
   privleap-tests-fuzz-atheris
   privleap-tests-session-fuzz
   sanitize-string-tests-fuzz
   sdwdate-gui-tests-fuzz
   secure-terminal-tests-fuzz
   stcat-family-tests-fuzz
   stdisplay-tests-fuzz
   tor-control-panel-tests-fuzz
   unicode-show-tests-fuzz
)
e2e_suites=(
   onion-grater-tests-e2e
   privleap-tests-e2e
   privleap-tests-e2e-systemd
)
integration_suites=(
   sdwdate-gui-tests-integration
   secure-terminal-tests-apparmor
)

usage() {
   cat <<'EOF'
Usage:
  dist-ai-tests-all [--core] [--fuzz] [--e2e] [--integration] [--all]
                    [--repo-root DIR]
                    [--component NAME [--component-root DIR]]
                    [--helper-scripts-root DIR]
                    [--progress FILE]
                    [--timeout-core N] [--timeout-fuzz N] [--timeout-heavy N]
                    [--list]

With no category flag, only --core runs.

--repo-root points every suite at a derivative-maker MONOREPO checkout
(packages/<team>/<name>); without it each suite falls back to its installed
/ auto path. A suite that cannot find its target exits 77 and is reported SKIP.

--component NAME restricts the run to the suites owned by ONE component
(privleap, helper-scripts, onion-grater, genmkfile, open-link-confirmation,
sdwdate-gui, developer-meta-files, derivative-maker). --component-root DIR points those suites at
a STANDALONE component checkout -- the repo root itself, not a monorepo subpath
-- which is the per-repo CI entry point. --component-root requires --component.

--helper-scripts-root DIR supplies a helper-scripts checkout for components
whose suites drive a helper-scripts tool (open-link-confirmation ->
sanitize-string), needed in standalone-component mode where no sibling
helper-scripts checkout exists.

--skip NAME drops the suite entrypoint NAME from the run (repeatable), e.g. a
suite temporarily broken or pending a merge, so a component's other suites can
still gate PRs.
EOF
}

## Resolve a package checkout path under --repo-root, or empty when unset.
pkg_dir() {
   local name="$1"
   ## Standalone-component override: the selected component's checkout root is
   ## given directly (the repo root itself), bypassing the monorepo
   ## packages/<team>/<name> join. This is the per-repo CI path.
   if [ -n "${component_root}" ] && [ "${name}" = "${component}" ]; then
      printf '%s' "${component_root}"
      return 0
   fi
   ## Auxiliary helper-scripts checkout: some components' suites drive a
   ## helper-scripts tool (open-link-confirmation -> sanitize-string). In
   ## standalone-component mode there is no sibling helper-scripts, so accept
   ## its root explicitly via --helper-scripts-root.
   if [ -n "${helper_scripts_root}" ] && [ "${name}" = 'helper-scripts' ]; then
      printf '%s' "${helper_scripts_root}"
      return 0
   fi
   [ -n "${repo_root}" ] || return 0
   case "${name}" in
      ## derivative-maker is the monorepo itself, not a packages/ subpath.
      derivative-maker)
         printf '%s' "${repo_root}" ;;
      onion-grater)
         printf '%s' "${repo_root}/packages/whonix/onion-grater" ;;
      *)
         printf '%s' "${repo_root}/packages/kicksecure/${name}" ;;
   esac
}

## Given a suite name, populate wire_env (array of VAR=VALUE) and wire_args
## (array of positional args) so the suite targets the checkout. No-op when
## --repo-root is unset.
wire() {
   local suite="$1"
   local base="${suite%%-tests*}"
   wire_env=()
   wire_args=()
   [ -n "${repo_root}" ] || [ -n "${component_root}" ] || return 0

   local hs dmf
   hs="$( pkg_dir helper-scripts )"
   dmf="$( pkg_dir developer-meta-files )"

   case "${base}" in
      check-ref-commits-for-unicode)
         wire_env=( "CHECK_REF_COMMITS_REPO=${hs}" ) ;;
      grep-find-unicode-wrapper)
         wire_env=( "GREP_FIND_UNICODE_WRAPPER_REPO=${hs}" ) ;;
      unicode-show)
         wire_env=( "UNICODE_SHOW_REPO=${hs}" ) ;;
      stcat-family|stdisplay)
         wire_env=( "STDISPLAY_REPO=${hs}" ) ;;
      sanitize-string)
         ## sanitize-string's '#!/usr/bin/python3 -Bsu' excludes the user site,
         ## so from a checkout (not installed) it needs its dist-packages on
         ## PYTHONPATH -- else it dies with ModuleNotFoundError and prints
         ## nothing, which safety checks then pass on trivially (false green).
         wire_env=(
            "SANITIZE_STRING_BIN=${hs}/usr/bin/sanitize-string"
            "PYTHONPATH=${hs}/usr/lib/python3/dist-packages"
         ) ;;
      onion-grater)
         wire_env=( "ONION_GRATER_REPO=$( pkg_dir onion-grater )" ) ;;
      privleap)
         wire_env=( "PRIVLEAP_REPO=$( pkg_dir privleap )" ) ;;
      genmkfile)
         ## genmkfile's make-helper sources helper-scripts at runtime (has.sh,
         ## trace.bsh) and shells out to its tools; give it the full
         ## helper-scripts runtime (env here; the /usr/libexec/helper-scripts
         ## system path is provided by the CI setup step) when a helper-scripts
         ## checkout is available.
         wire_env=( "GENMKFILE_BIN=$( pkg_dir genmkfile )/usr/bin/genmkfile" )
         if [ -n "${hs}" ]; then
            wire_env+=(
               "HELPER_SCRIPTS_PATH=${hs}"
               "PATH=${hs}/usr/bin:${PATH}"
               "PYTHONPATH=${hs}/usr/lib/python3/dist-packages"
            )
         fi
         ;;
      open-link-confirmation)
         ## PYTHONPATH so the checkout's sanitize-string can import its library
         ## (see the sanitize-string note); without it sanitize-string emits
         ## nothing and the display-safety checks pass vacuously.
         wire_env=(
            "OPEN_LINK_CONFIRMATION_BIN=$( pkg_dir open-link-confirmation )/usr/libexec/open-link-confirmation/open-link-confirmation"
            "SANITIZE_STRING_BIN=${hs}/usr/bin/sanitize-string"
            "PYTHONPATH=${hs}/usr/lib/python3/dist-packages"
         ) ;;
      sdwdate-gui)
         wire_env=( "PYTHONPATH=$( pkg_dir sdwdate-gui )/usr/lib/python3/dist-packages" ) ;;
      msgcollector)
         ## The fuzzer extracts msgcollector's CLI-rendering bash from the one
         ## script and runs it in isolation; no other runtime needed.
         wire_env=( "MSGCOLLECTOR_REPO=$( pkg_dir msgcollector )" ) ;;
      systemcheck)
         ## The scenario harness runs the REAL check_*.bsh fragments, several of
         ## which sanitize untrusted output with the bare `sanitize-string`
         ## helper-scripts tool (check_dpkg, check_hostname, ...). Put the
         ## helper-scripts checkout's usr/bin on PATH so that tool resolves, and
         ## its dist-packages on PYTHONPATH (sanitize-string's '-Bsu' shebang
         ## excludes the user site, so from a checkout it needs its library
         ## there -- else it dies with ModuleNotFoundError and emits nothing,
         ## which the display-safety checks then pass on vacuously).
         wire_env=( "SYSTEMCHECK_REPO=$( pkg_dir systemcheck )" )
         if [ -n "${hs}" ]; then
            wire_env+=(
               "PATH=${hs}/usr/bin:${PATH}"
               "PYTHONPATH=${hs}/usr/lib/python3/dist-packages"
            )
         fi
         ;;
      tor-control-panel)
         ## tcp_testlib resolves the package under test from TCP_REPO (the
         ## tor-control-panel checkout root) else the installed package. The
         ## merged anon-connection-wizard imports guimessages from
         ## helper-scripts, so put helper-scripts on PYTHONPATH when available.
         wire_env=( "TCP_REPO=$( pkg_dir tor-control-panel )" )
         if [ -n "${hs}" ]; then
            wire_env+=( "PYTHONPATH=${hs}/usr/lib/python3/dist-packages" )
         fi
         ;;
      git-meld)
         wire_args=( "${dmf}/usr/bin/git-meld" ) ;;
      dm-virtualbox-wiki-links)
         wire_args=( "${dmf}/usr/bin/dm-virtualbox-update-local-and-wiki-links" ) ;;
      dm-help-steps)
         wire_env=( "UMOUNT_KILL_SH=$( pkg_dir derivative-maker )/help-steps/umount_kill.sh" ) ;;
      web-analyzer)
         ## analyzer.js lives in output-lies.github.io, not a derivative-maker
         ## component, so there is nothing under --repo-root to point at; it is
         ## resolved from OUTPUT_LIES_REPO in the ambient environment instead.
         wire_env=() ; wire_args=() ;;
      website)
         ## the Pages sites live in their own repos, not a derivative-maker
         ## component; the suite resolves each from OUTPUT_LIES_REPO /
         ## SECURE_TERMINAL_SITE_REPO / ORG_AI_ASSISTED_REPO in the ambient
         ## environment (or a private-sources default) instead.
         wire_env=() ; wire_args=() ;;
      secure-terminal)
         ## secure_terminal lives in its own repo (a --component checkout), not a
         ## derivative-maker packages/ subpath; point the suite at it via
         ## SECURE_TERMINAL_REPO resolved from the component root.
         wire_env=( "SECURE_TERMINAL_REPO=$( pkg_dir secure-terminal )" ) ;;
      *)
         printf 'dist-ai-tests-all: no wiring for suite %s\n' "${suite}" >&2
         return 1 ;;
   esac
}

## Map a suite entrypoint to the standalone component (repo) that ships the
## code it tests. Mirrors the base-name grouping in wire(); used by --component
## to restrict the run to one repo's suites. An unrecognized suite yields the
## empty string (matches no component).
suite_component() {
   local base="${1%%-tests*}"
   case "${base}" in
      check-ref-commits-for-unicode|grep-find-unicode-wrapper|unicode-show|stcat-family|stdisplay|sanitize-string)
         printf '%s' 'helper-scripts' ;;
      git-meld|dm-virtualbox-wiki-links)
         printf '%s' 'developer-meta-files' ;;
      dm-help-steps)          printf '%s' 'derivative-maker' ;;
      onion-grater)           printf '%s' 'onion-grater' ;;
      privleap)               printf '%s' 'privleap' ;;
      genmkfile)              printf '%s' 'genmkfile' ;;
      msgcollector)           printf '%s' 'msgcollector' ;;
      open-link-confirmation) printf '%s' 'open-link-confirmation' ;;
      sdwdate-gui)            printf '%s' 'sdwdate-gui' ;;
      secure-terminal)        printf '%s' 'secure-terminal' ;;
      systemcheck)            printf '%s' 'systemcheck' ;;
      tor-control-panel)      printf '%s' 'tor-control-panel' ;;
   esac
}

emit() {
   local line="$1"
   printf '%s\n' "${line}"
   if [ -n "${progress_file}" ]; then
      printf '%s\n' "${line}" >> "${progress_file}"
   fi
}

pass_count=0
fail_count=0
skip_count=0

run_suite() {
   local suite="$1" category="$2" tmo="$3"
   local entry="${mydir}/${suite}"
   if [ ! -x "${entry}" ]; then
      emit "$( printf '%-38s %-12s MISSING' "${suite}" "[${category}]" )"
      skip_count=$(( skip_count + 1 ))
      return 0
   fi
   wire "${suite}"
   local rc=0
   timeout "${tmo}" env "${wire_env[@]}" "${entry}" "${wire_args[@]}" \
      >"/tmp/dist-ai-tests-all.${suite}.log" 2>&1 || rc=$?
   local verdict log_line
   case "${rc}" in
      0)   verdict="PASS" ;    pass_count=$(( pass_count + 1 )) ;;
      77)  verdict="SKIP" ;    skip_count=$(( skip_count + 1 )) ;;
      124) verdict="TIMEOUT" ; fail_count=$(( fail_count + 1 )) ;;
      *)   verdict="FAIL(${rc})" ; fail_count=$(( fail_count + 1 )) ;;
   esac
   emit "$( printf '%-38s %-12s %s' "${suite}" "[${category}]" "${verdict}" )"
   ## Surface the failing suite's captured output inline: the per-suite log
   ## lives in /tmp, which CI discards, so a bare FAIL verdict is not
   ## actionable. Echo it on FAIL / TIMEOUT (not on PASS / SKIP).
   case "${rc}" in
      0|77) : ;;
      *)
         emit "---- ${suite}: begin captured output (${verdict}) ----"
         while IFS= read -r log_line; do
            emit "${log_line}"
         done < "/tmp/dist-ai-tests-all.${suite}.log"
         emit "---- ${suite}: end captured output ----"
         ;;
   esac
}

## Captured before the parse loop shifts them away, so the sandbox gate can echo
## the exact invocation back in its "run it this way instead" hint.
orig_args=( "$@" )

while [ "$#" -gt 0 ]; do
   case "$1" in
      --core)          run_core="true" ;;
      --fuzz)          run_fuzz="true" ;;
      --e2e)           run_e2e="true" ;;
      --integration)   run_integration="true" ;;
      --all)           run_core="true" ; run_fuzz="true" ; run_e2e="true" ; run_integration="true" ;;
      --repo-root)      repo_root="$2" ; shift ;;
      --component)      component="$2" ; shift ;;
      --component-root) component_root="$2" ; shift ;;
      --helper-scripts-root) helper_scripts_root="$2" ; shift ;;
      --skip)           skip_suites+=( "$2" ) ; shift ;;
      --progress)      progress_file="$2" ; shift ;;
      --timeout-core)  timeout_core="$2" ; shift ;;
      --timeout-fuzz)  timeout_fuzz="$2" ; shift ;;
      --timeout-heavy) timeout_heavy="$2" ; shift ;;
      --list)          list_only="true" ;;
      --help|-h)       usage ; exit 0 ;;
      *)               printf 'dist-ai-tests-all: unknown option: %s\n' "$1" >&2 ; exit 2 ;;
   esac
   shift
done

## Default: core only.
if [ "${run_core}" = "false" ] && [ "${run_fuzz}" = "false" ] \
   && [ "${run_e2e}" = "false" ] && [ "${run_integration}" = "false" ]; then
   run_core="true"
fi

if [ -n "${repo_root}" ] && [ ! -d "${repo_root}" ]; then
   printf 'dist-ai-tests-all: --repo-root not a directory: %s\n' "${repo_root}" >&2
   exit 2
fi

if [ -n "${component}" ]; then
   case "${component}" in
      helper-scripts|developer-meta-files|derivative-maker|msgcollector|onion-grater|privleap|genmkfile|open-link-confirmation|sdwdate-gui|secure-terminal|systemcheck|tor-control-panel)
         : ;;
      *)
         printf 'dist-ai-tests-all: unknown --component: %s\n' "${component}" >&2
         exit 2 ;;
   esac
fi

if [ -n "${component_root}" ]; then
   if [ -z "${component}" ]; then
      printf 'dist-ai-tests-all: --component-root requires --component\n' >&2
      exit 2
   fi
   if [ ! -d "${component_root}" ]; then
      printf 'dist-ai-tests-all: --component-root not a directory: %s\n' "${component_root}" >&2
      exit 2
   fi
fi

if [ -n "${helper_scripts_root}" ] && [ ! -d "${helper_scripts_root}" ]; then
   printf 'dist-ai-tests-all: --helper-scripts-root not a directory: %s\n' "${helper_scripts_root}" >&2
   exit 2
fi

selected=()
[ "${run_core}" = "true" ]        && selected+=( "${core_suites[@]/#/core:}" )
[ "${run_fuzz}" = "true" ]        && selected+=( "${fuzz_suites[@]/#/fuzz:}" )
[ "${run_e2e}" = "true" ]         && selected+=( "${e2e_suites[@]/#/e2e:}" )
[ "${run_integration}" = "true" ] && selected+=( "${integration_suites[@]/#/integration:}" )

## --component: keep only the suites owned by that component.
if [ -n "${component}" ]; then
   filtered=()
   for item in "${selected[@]}"; do
      if [ "$( suite_component "${item#*:}" )" = "${component}" ]; then
         filtered+=( "${item}" )
      fi
   done
   selected=( "${filtered[@]}" )
fi

## --skip: drop named suite entrypoints (e.g. one temporarily broken / pending a
## merge) so the rest of a component's suites can still gate PRs.
if [ "${#skip_suites[@]}" -gt 0 ]; then
   filtered=()
   for item in "${selected[@]}"; do
      suite="${item#*:}"
      skip_this="false"
      for skip_name in "${skip_suites[@]}"; do
         if [ "${suite}" = "${skip_name}" ]; then
            skip_this="true"
            break
         fi
      done
      [ "${skip_this}" = "false" ] && filtered+=( "${item}" )
   done
   selected=( "${filtered[@]}" )
fi

if [ "${list_only}" = "true" ]; then
   printf '%s\n' "${selected[@]}"
   exit 0
fi

## Extra-safety gate: OUTSIDE GitHub CI, dist-ai tests must run INSIDE the sandbox
## VM, never directly on a workstation -- a suite may mount, remove files, or need
## root, and the sandbox contains the blast radius. Enforced HERE in code, not left
## to operator discipline. Exempt: GitHub CI (ephemeral, isolated runners) and one
## documented override env var. (--list already exited above, so listing is free.)
enforce_sandbox_only() {
   [ "${GITHUB_ACTIONS:-}" = "true" ] && return 0     # GitHub Actions runner
   [ "${CI:-}" = "true" ] && return 0                 # generic CI (also set by GitHub)
   [ "${DIST_AI_IN_SANDBOX:-}" = "1" ] && return 0    # already routed into the sandbox
   if [ "${DIST_AI_ALLOW_HOST_TESTS:-}" = "1" ]; then
      printf 'dist-ai-tests-all: WARNING: DIST_AI_ALLOW_HOST_TESTS=1 -- running on the host; sandbox safety gate bypassed.\n' >&2
      return 0
   fi
   {
      printf 'dist-ai-tests-all: refusing to run on the host for safety.\n'
      printf '  Outside GitHub CI, dist-ai tests must run inside the sandbox VM (a\n'
      printf '  suite may mount, remove files, or need root). Run them in the sandbox:\n'
      printf '    sandbox-run --dir . -- env DIST_AI_IN_SANDBOX=1 dist-ai-tests-all %s\n' "${orig_args[*]:-}"
      printf '  Or, to deliberately run on THIS host, set DIST_AI_ALLOW_HOST_TESTS=1.\n'
   } >&2
   exit 3
}
enforce_sandbox_only

emit "== dist-ai-tests-all: $( date --utc '+%Y-%m-%dT%H:%M:%SZ' ) =="
[ -n "${repo_root}" ] && emit "== repo-root: ${repo_root} =="

for item in "${selected[@]}"; do
   category="${item%%:*}"
   suite="${item#*:}"
   case "${category}" in
      core)        run_suite "${suite}" "${category}" "${timeout_core}" ;;
      fuzz)        run_suite "${suite}" "${category}" "${timeout_fuzz}" ;;
      e2e|integration) run_suite "${suite}" "${category}" "${timeout_heavy}" ;;
   esac
done

emit "== summary: ${pass_count} pass, ${fail_count} fail, ${skip_count} skip/missing =="
emit "== per-suite output: /tmp/dist-ai-tests-all.<suite>.log =="

[ "${fail_count}" -eq 0 ]
