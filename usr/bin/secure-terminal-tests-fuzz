#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy randomized fuzz run of secure-terminal's untrusted-input parsers: the
## output renderer and raw-byte decoder, the line-mode logical-cell editor and
## its renderers, the per-cell TUI sanitizer, the SGR colour parser, the paste
## sanitizers/classifiers, the title sanitizer, the config drop-in parser, the
## session loader, the IPC frame reassembler, and the hook rules/gate parsers.
## An ESCAPE-BIASED generator keeps trying to smuggle a dangerous code point
## past the sanitizer; every iteration is checked against an independent
## terminal-safety oracle and per-function invariants. Override with
## --iterations N / --seed N; a failure prints the seed to replay. Same target
## resolution and SECURE_TERMINAL_REPO override as secure-terminal-tests; a
## missing checkout SKIPs (exit 77) rather than failing.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-tests' ]; then
   tests_dir='/usr/share/secure-terminal-tests'
else
   tests_dir="${script_dir}/../share/secure-terminal-tests"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-tests-fuzz: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"

iterations='40000'

## Run the fuzzer as a child and forward its exit code (no exec / process
## replacement). errexit propagates a non-zero status as this script's own.
python3 -Bsu -- "${tests_dir}/fuzz_secure_terminal.py" \
   --iterations "${iterations}" "$@"
