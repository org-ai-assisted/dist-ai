#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Runs developer-meta-files' style-gate verification: drives the real, shipped
## agents/pre-push-static.sh against throwaway git repos, asserting the
## single-grep style checks flag violations and spare compliant files. Needs
## the developer-meta-files checkout (DMF_REPO, wired by dist-ai-tests-all via
## --component developer-meta-files --component-root) plus helper-scripts'
## has.sh, git and safe-rm. Exits 77 (SKIP) if a prerequisite is absent. Works
## installed (/usr/share/developer-meta-files-tests) or from a checkout.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/developer-meta-files-tests' ]; then
   share='/usr/share/developer-meta-files-tests'
else
   share="${script_dir}/../share/developer-meta-files-tests"
fi

if [ -z "${DMF_REPO:-}" ]; then
   printf '%s\n' 'developer-meta-files-tests: DMF_REPO unset (run with --component developer-meta-files --component-root DIR); skipping.' >&2
   exit 77
fi
if [ ! -x "${DMF_REPO}/agents/pre-push-static.sh" ]; then
   printf '%s\n' "developer-meta-files-tests: '${DMF_REPO}/agents/pre-push-static.sh' not found; skipping." >&2
   exit 77
fi
if [ ! -r '/usr/libexec/helper-scripts/has.sh' ]; then
   printf '%s\n' 'developer-meta-files-tests: helper-scripts has.sh not installed; skipping.' >&2
   exit 77
fi

## Run the test as a child and forward its exit code (no process-replacing
## exec). DMF_REPO is inherited from this environment.
rc=0
"${share}/test_pre_push_static_style_rules.sh" "$@" || rc="$?"
exit "$rc"
