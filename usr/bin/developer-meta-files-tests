#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Runs developer-meta-files' functional tests against the checkout:
##   * test_pre_push_static_style_rules.sh -- drives the real, shipped
##     pre-push-static gate (dist-ai) and asserts its single-grep style checks
##     flag violations and spare compliant files;
##   * test_dm_review_branch.sh -- asserts dm-review-branch aborts on suspicious
##     unicode in a reviewed branch's commits AND in any ref name.
## Both resolve the developer-meta-files checkout from DMF_REPO (wired by
## dist-ai-tests-all via --component developer-meta-files --component-root).
## Each test SKIPs itself (exit 77) when its own prerequisites are absent, so a
## missing helper (shellcheck, helper-scripts) skips rather than false-fails.
## Works installed (/usr/share/developer-meta-files-tests) or from a checkout.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/developer-meta-files-tests' ]; then
   share='/usr/share/developer-meta-files-tests'
else
   share="${script_dir}/../share/developer-meta-files-tests"
fi

if [ -z "${DMF_REPO:-}" ]; then
   printf '%s\n' 'developer-meta-files-tests: DMF_REPO unset (run with --component developer-meta-files --component-root DIR); skipping.' >&2
   exit 77
fi
export DMF_REPO

## The dm-review-branch test drives helper-scripts' check-ref-*-for-unicode /
## unicode-show. When a helper-scripts checkout is wired, put its usr/bin on
## PATH (and export the var, which those tools use to source their own libs) so
## the test runs instead of skipping.
if [ -n "${HELPER_SCRIPTS_PATH:-}" ]; then
   export HELPER_SCRIPTS_PATH
   export PATH="${HELPER_SCRIPTS_PATH}/usr/bin:${PATH}"
   ## unicode-show (driven by check-ref-*-for-unicode) has a '-Bsu' shebang
   ## that excludes the user site, so from a checkout it needs its library on
   ## PYTHONPATH -- else it dies with ModuleNotFoundError and the review fails.
   export PYTHONPATH="${HELPER_SCRIPTS_PATH}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"
fi

shopt -s nullglob
tests=( "${share}"/test_*.sh )
if [ "${#tests[@]}" -eq 0 ]; then
   printf '%s\n' "developer-meta-files-tests: no test_*.sh under '${share}'; skipping." >&2
   exit 77
fi

## Run each test; 0 = pass, 77 = skip (its own prerequisites absent), anything
## else = fail. Report per test and fail the suite if any test failed.
failed=0
ran=0
skipped=0
for test_path in "${tests[@]}"; do
   test_name="$(basename -- "${test_path}")"
   rc=0
   "${test_path}" "$@" || rc="$?"
   case "${rc}" in
      0)
         ran=$(( ran + 1 ))
         printf 'developer-meta-files-tests: PASS %s\n' "${test_name}" ;;
      77)
         skipped=$(( skipped + 1 ))
         printf 'developer-meta-files-tests: SKIP %s\n' "${test_name}" ;;
      *)
         failed=$(( failed + 1 ))
         printf 'developer-meta-files-tests: FAIL %s (exit %s)\n' "${test_name}" "${rc}" >&2 ;;
   esac
done

printf 'developer-meta-files-tests: %d passed, %d skipped, %d failed.\n' \
   "${ran}" "${skipped}" "${failed}"

if [ "${failed}" -gt 0 ]; then
   exit 1
fi
## All tests skipped (no prerequisites anywhere) -> SKIP the suite, not a
## vacuous pass.
if [ "${ran}" -eq 0 ]; then
   exit 77
fi
exit 0
