#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## Runs the in-process privleap security suite (no root, no network, no live
## privleapd): the server-side wire-protocol parser fuzzer and the
## authorization-engine property test, both with a fixed seed for reproducible
## CI. These exercise exactly the code an unprivileged local user can reach
## over their comm socket, the surface where a bug could become arbitrary code
## execution. For randomized fuzzing with a coverage report use
## privleap-tests-fuzz; for the live-daemon integration test use
## privleap-tests-e2e. Targets the installed privleap by default; set
## PRIVLEAP_REPO to a derivative-maker checkout to test that tree instead.
## Works installed (/usr/share/privleap-tests) or from a git checkout.

set -o nounset
set -o pipefail
set -o errtrace
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/privleap-tests' ]; then
  tests_dir='/usr/share/privleap-tests'
else
  tests_dir="${script_dir}/../share/privleap-tests"
fi

overall=0
saw_pass=0

run_one() {
  local rc=0
  python3 -- "$@" || rc=$?
  if [ "${rc}" = '77' ]; then
    ## TAP/automake "skipped"; only fatal if nothing else passed.
    return 0
  fi
  if [ "${rc}" != '0' ]; then
    overall=1
  else
    saw_pass=1
  fi
  return 0
}

echo '################ parser fuzzer (in-process) ################'
run_one "${tests_dir}/parser_fuzz.py" --seed 1 --iterations 4000
echo
echo '############ authorization-engine property test ###########'
run_one "${tests_dir}/authorizer_test.py" --seed 1 --iterations 3000

echo
if [ "${overall}" != '0' ]; then
  echo 'privleap-tests: OVERALL RESULT: FAIL'
  exit 1
fi
if [ "${saw_pass}" = '0' ]; then
  echo 'privleap-tests: OVERALL RESULT: SKIPPED (privleap not found)'
  exit 77
fi
echo 'privleap-tests: OVERALL RESULT: PASS'
exit 0
