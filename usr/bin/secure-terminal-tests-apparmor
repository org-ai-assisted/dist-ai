#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Verify the shipped secure-terminal AppArmor profile actually ENFORCES: it
## DENIES a path it does not grant and ALLOWS one it does. This proves the
## confinement is real, not merely declared -- the check that backs the "AppArmor
## stays enforceable" claims (sound files, terminfo, general read confinement).
##
## Loading a profile is system-wide and needs root + a running AppArmor, so this
## exits 77 (SKIP) anywhere that is not satisfied -- it is meant for the
## AppArmor-capable disposable sandbox / CI, NEVER a dev host (enforcing there
## could confine the running desktop). It restores the prior state on exit.
##
## In the disposable sandbox we WANT it to RUN (not skip): if not root but running
## inside the sandbox with passwordless sudo, re-run under sudo. Guarded to the
## sandbox marker so a dev host still SKIPs rather than enforcing on the desktop.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=../../../helper-scripts/usr/libexec/helper-scripts/has.sh
# shellcheck disable=SC1091
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/has.sh

skip() {
   printf 'secure-terminal-tests(apparmor): SKIP -- %s\n' "$1"
   exit 77
}

if [ "$( id -u )" -ne 0 ]; then
   in_sandbox=""
   [ "${DIST_AI_IN_SANDBOX:-}" = "1" ] && in_sandbox="yes"
   [ "${POC_CORPUS_IN_SANDBOX:-}" = "1" ] && in_sandbox="yes"
   if [ -n "${in_sandbox}" ] \
      && has apparmor_parser \
      && has aa-exec \
      && sudo -n true >/dev/null 2>&1; then
      rc=0
      sudo -n --preserve-env=SECURE_TERMINAL_REPO bash "$0" "$@" || rc="$?"
      exit "${rc}"
   fi
fi

[ "$( id -u )" -eq 0 ] || skip "needs root (loads a profile system-wide)"
has apparmor_parser \
   && has aa-exec \
   || skip "apparmor tooling (apparmor_parser / aa-exec) not present"
aa-status --enabled >/dev/null 2>&1 || skip "apparmor not enabled in this kernel"

## Locate the profile: an installed copy, or the checkout via SECURE_TERMINAL_REPO.
profile=""
for candidate in \
   "${SECURE_TERMINAL_REPO:-}/etc/apparmor.d/secure-terminal" \
   /etc/apparmor.d/secure-terminal; do
   if [ -n "${candidate}" ] && [ -r "${candidate}" ]; then
      profile="${candidate}"
      break
   fi
done
[ -n "${profile}" ] || skip "profile not found (set SECURE_TERMINAL_REPO)"

apparmor_remove_profile() {
   apparmor_parser --remove "${profile}" >/dev/null 2>&1 || true
}

apparmor_parser --replace --skip-cache "${profile}"
trap apparmor_remove_profile EXIT

pass=0
fail=0

## ALLOW: a path the profile grants (/usr/share/secure-terminal/{,**} r).
allow_dir=/usr/share/secure-terminal
mkdir --parents "${allow_dir}"
allow_probe="${allow_dir}/aa-enforce-probe"
printf granted > "${allow_probe}"
allow_rc=0
aa-exec -p secure-terminal -- cat "${allow_probe}" >/dev/null 2>&1 || allow_rc=$?
if [ "${allow_rc}" -eq 0 ]; then
   pass=$(( pass + 1 ))
else
   fail=$(( fail + 1 ))
   printf 'FAIL: the profile DENIED a granted path (%s)\n' "${allow_probe}"
fi

## DENY: a path the profile does not grant (AppArmor is default-deny once loaded).
deny_probe=/root/aa-enforce-deny-probe
printf secret > "${deny_probe}"
deny_rc=0
aa-exec -p secure-terminal -- cat "${deny_probe}" >/dev/null 2>&1 || deny_rc=$?
if [ "${deny_rc}" -ne 0 ]; then
   pass=$(( pass + 1 ))
else
   fail=$(( fail + 1 ))
   printf 'FAIL: the profile ALLOWED a non-granted path (%s) -- NOT enforcing\n' \
      "${deny_probe}"
fi

## ALLOW (write): the predefined canary subtree that `secure-terminal
## --test-canary` writes. This proves the profile GRANTS the confined terminal a
## write to exactly that folder -- so the EICAR-style positive control still fires
## under enforcement (a confined WRITE, complementing the read allow/deny above).
## uid 0 here -> /run/user/0; the profile pattern is /run/user/[0-9]*/.
canary_dir="/run/user/$(id --user)/secure-terminal/canary"
mkdir --parents "${canary_dir}"
canary_probe="${canary_dir}/canary"
## Source from a path the profile ALREADY grants read (/usr/share/secure-terminal
## r), so a source-read denial cannot masquerade as a destination-write denial --
## this probe must isolate the canary WRITE grant.
canary_src="${allow_dir}/aa-canary-src"
printf token > "${canary_src}"
canary_rc=0
## cp is the aa-exec target, so it runs CONFINED as secure-terminal; its write to
## the destination is subject to the profile.
aa-exec -p secure-terminal -- cp "${canary_src}" "${canary_probe}" \
   >/dev/null 2>&1 || canary_rc=$?
if [ "${canary_rc}" -eq 0 ] && [ -s "${canary_probe}" ]; then
   pass=$(( pass + 1 ))
else
   fail=$(( fail + 1 ))
   printf 'FAIL: the profile DENIED the predefined canary write (%s)\n' \
      "${canary_probe}"
fi

safe-rm --force "${allow_probe}" "${deny_probe}" "${canary_src}" "${canary_probe}"
rmdir "${canary_dir}" 2>/dev/null || true
printf 'secure-terminal-tests(apparmor): %d passed, %d failed\n' "${pass}" "${fail}"
[ "${fail}" -eq 0 ]
