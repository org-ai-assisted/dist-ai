#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Boot a built derivative-maker ISO headless over the serial console and run
## systemcheck leak tests in the sysmaint and user sessions. Works both when
## installed (driver under /usr/share/iso-boot-tests) and when run straight from
## a git checkout (usr/share/iso-boot-tests relative to this script). All
## arguments are forwarded to run_leaktests.py -- notably:
##   --iso PATH               the ISO to boot (absent -> SKIP, exit 77)
##   --dm-qemu PATH           derivative-maker help-steps/dm-qemu (or set
##                            DERIVATIVE_MAKER_DIR / default ~/derivative-maker)
##   --fast                   mitigations=off for pure-TCG hosts (not a fidelity test)
##
## This runs on the BUILD HOST (needs qemu + the ISO), not inside the guest.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/iso-boot-tests' ]; then
   tests_dir='/usr/share/iso-boot-tests'
else
   tests_dir="${script_dir}/../share/iso-boot-tests"
fi

rc=0
python3 -Bsu "${tests_dir}/run_leaktests.py" "$@" || rc=$?
exit "$rc"
