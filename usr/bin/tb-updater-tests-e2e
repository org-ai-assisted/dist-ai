#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Runs tb-updater's end-to-end suite: drives the REAL installed
## update-torbrowser (and the update-mullvadbrowser / update-i2pbrowser
## wrappers) against local file:// signing fixtures in an isolated HOME, with
## no network. Covers fresh install, the signature-freshness cache, downgrade
## and freeze warnings, rejection of tampered/invalid/too-old/wrong-signer
## signatures, and a '--input gui' scenario that stubs the msgcollector dialogs
## and asserts the whole download -> verify -> extract -> install path
## completes.
##
## Needs the tb-updater package installed (update-torbrowser sources absolute
## /usr/libexec paths) plus sqop for fixture signing. Exits 77 (SKIP) if either
## is absent. Works installed (/usr/share/tb-updater-tests) or from a checkout.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

## style-ok: no-has -- test entrypoint; probes for sqop with 'command -v'
## rather than helper-scripts' 'has', which is not guaranteed on PATH here.

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/tb-updater-tests/e2e' ]; then
   e2e_dir='/usr/share/tb-updater-tests/e2e'
else
   e2e_dir="${script_dir}/../share/tb-updater-tests/e2e"
fi

if [ ! -x /usr/bin/update-torbrowser ]; then
   printf '%s\n' 'tb-updater-tests-e2e: /usr/bin/update-torbrowser not installed; skipping.' >&2
   exit 77
fi
if ! command -v sqop >/dev/null; then
   printf '%s\n' 'tb-updater-tests-e2e: sqop not installed (Debian: sqop); skipping.' >&2
   exit 77
fi

## Gate the harness scripts so they cannot be mis-invoked directly on a real
## system; each scenario still isolates HOME so nothing outside a temp dir is
## touched.
export TB_UPDATER_TESTS_E2E=1

## Run the harness as a child and forward its exit code (no process-replacing
## exec).
rc=0
"${e2e_dir}/run-e2e" "$@" || rc="$?"
exit "$rc"
