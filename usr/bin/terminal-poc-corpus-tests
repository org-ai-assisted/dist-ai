#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Runs the terminal-poc-corpus security test surface against secure-terminal:
##
##   - the adversarial harness (harness/adversarial.py): its --self-test proves
##     every detector fires on a synthetic vulnerable observable, then the run
##     asserts secure-terminal neutralizes all corpus PoCs (no reflection to the
##     pty, no deception, no exfil);
##   - the conformance harness (harness/conformance.py): the reference parsers
##     (pyte, libvterm) pass their own tests at the reviewed pin, and every escape
##     sequence the reviewed conformance suites exercise upholds the security
##     invariants when fed to secure-terminal (zero pty write-back, pure-ASCII
##     rendered text, no crash) across the whole VT/xterm spec surface.
##
## Targets a terminal-poc-corpus checkout (TERMINAL_POC_CORPUS_REPO, else a
## private-sources default or a sibling component checkout) and a secure-terminal
## checkout (SECURE_TERMINAL_REPO, likewise). SKIPs (exit 77) when either is
## absent, or when PyQt6 / pyte (the corpus harness's hard dependencies) are not
## installed. The external conformance suites are acquired best-effort over the
## network (pinned commit SHAs); whatever cannot be fetched is skipped inside the
## harness, and the always-run baseline invariant still exercises the reflection
## surface. No root.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

## Resolve the terminal-poc-corpus checkout.
corpus=''
[ -v TERMINAL_POC_CORPUS_REPO ] || TERMINAL_POC_CORPUS_REPO=''
if [ -n "${TERMINAL_POC_CORPUS_REPO}" ]; then
   corpus="${TERMINAL_POC_CORPUS_REPO}"
elif [ -d "${HOME}/private-sources/terminal-poc-corpus/harness" ]; then
   corpus="${HOME}/private-sources/terminal-poc-corpus"
elif [ -d "${script_dir}/../../../../terminal-poc-corpus/harness" ]; then
   corpus="${script_dir}/../../../../terminal-poc-corpus"
fi

if [ -z "${corpus}" ] || [ ! -f "${corpus}/harness/conformance.py" ]; then
   printf 'terminal-poc-corpus-tests: SKIP (terminal-poc-corpus not found; set TERMINAL_POC_CORPUS_REPO)\n' >&2
   exit 77
fi

## Resolve the secure-terminal checkout the harness drives.
repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'terminal-poc-corpus-tests: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

## The corpus harness drives the real (Qt) secure-terminal widget through pyte, so
## PyQt6 and pyte are hard dependencies here (unlike the Qt-free sanitize tests).
## Absent -> SKIP, matching the widget-test convention.
if ! python3 -c 'import PyQt6, pyte' 2>/dev/null; then
   printf 'terminal-poc-corpus-tests: SKIP (python3-pyqt6 / python3-pyte not installed)\n' >&2
   exit 77
fi

export SECURE_TERMINAL_REPO="${repo}"
export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"
## Offscreen Qt: no display in CI.
[ -v QT_QPA_PLATFORM ] || export QT_QPA_PLATFORM='offscreen'
## Mark the run confined so the harness will decode/feed live sequences. In real
## CI GITHUB_ACTIONS/CI already satisfy this; set the corpus flag too for a local
## sandbox run under dist-ai.
export DIST_AI_IN_SANDBOX='1'

## Best-effort acquisition of the reviewed external suites (pinned SHAs). Network
## may be unavailable; the harness skips whatever is missing, so never fail here.
if [ -x "${corpus}/conformance/acquire.sh" ]; then
   "${corpus}/conformance/acquire.sh" --for-tests || \
      printf 'terminal-poc-corpus-tests: note: suite acquisition incomplete (offline?); harness will skip unacquired suites\n' >&2
fi

overall=0
run_stage() {
   local label="$1"; shift
   printf '\n== %s ==\n' "${label}"
   if python3 -Bu -- "$@"; then
      return 0
   fi
   local rc="$?"
   if [ "${rc}" = '77' ]; then
      printf 'terminal-poc-corpus-tests: %s SKIPPED (exit 77)\n' "${label}" >&2
      return 0
   fi
   printf 'terminal-poc-corpus-tests: %s FAILED (exit %s)\n' "${label}" "${rc}" >&2
   overall=1
}

run_stage 'adversarial --self-test'  "${corpus}/harness/adversarial.py" --self-test
run_stage 'adversarial corpus'       "${corpus}/harness/adversarial.py"
run_stage 'conformance'              "${corpus}/harness/conformance.py" "$@"

exit "${overall}"
