#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Comprehensive test for the output-lies web text analyzer
## (output-lies.github.io: analyze/analyzer.js), the client-side, DOM-free
## classifier that flags every codepoint which is not plain printable ASCII:
## bidi controls, zero-width and invisible-format characters, deceptive
## whitespace, homoglyph-prone scripts, C0/C1 control bytes, line/paragraph
## separators, combining marks, tag characters, variation selectors and private
## use. The classifier is pure (no DOM), so this drives it directly under node
## with an exhaustive corpus of boundary codepoints and known real-world traps,
## plus analyze() token splitting, toAscii() stripping and hex() formatting. No
## root, no network. It targets an output-lies.github.io checkout resolved from
## OUTPUT_LIES_REPO (or a default under the operator's private-sources); if the
## module cannot be found it SKIPs (exit 77) rather than failing.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

# shellcheck source=../../../helper-scripts/usr/libexec/helper-scripts/has.sh
# shellcheck disable=SC1091
source "${HELPER_SCRIPTS_PATH:-}"/usr/libexec/helper-scripts/has.sh

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/web-analyzer-tests' ]; then
   tests_dir='/usr/share/web-analyzer-tests'
else
   tests_dir="${script_dir}/../share/web-analyzer-tests"
fi

node_bin=''
for candidate in node nodejs; do
   if has "${candidate}"; then
      node_bin="${candidate}"
      break
   fi
done

if [ -z "${node_bin}" ]; then
   printf 'web-analyzer-tests: SKIP (no node/nodejs interpreter found)\n' >&2
   exit 77
fi

"${node_bin}" -- "${tests_dir}/web_analyzer_test.js" "$@"
