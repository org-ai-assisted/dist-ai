#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy fuzz run of stdisplay(): same harness as stdisplay-tests with a large
## default iteration count per channel (random Unicode, an escape-biased
## smuggling channel that keeps trying to slip a dangerous escape past the SGR
## allow-list, and random exclude_sgr lists). Every iteration is checked against
## the independent terminal-safety oracle at every colour depth and for
## idempotence. Override with --iterations N / --seed N. See stdisplay-tests for
## the checks and the STDISPLAY_REPO override.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/stdisplay-tests' ]; then
   tests_dir='/usr/share/stdisplay-tests'
else
   tests_dir="${script_dir}/../share/stdisplay-tests"
fi

iterations='5000'

exec python3 -- "${tests_dir}/stdisplay_test.py" \
   --fuzz-only --iterations "${iterations}" "$@"
