#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## style-ok: no-safe-rm (rm -f of a mktemp temp only)

## Adversarial test runner for developer-meta-files' 'git-meld' external diff
## driver. Security property under test: a real submodule-gitlink change must
## NEVER be rendered as empty output (hidden from the reviewer). Regression
## guard for the '|| true'-hides-changes / '--no-ext-diff'-misplacement bugs.
##
## Usage:
##   git-meld-tests [/path/to/git-meld]
##   GIT_MELD_OLD_REF=<gitref> git-meld-tests   # also prove the OLD code hid changes
##
## Default git-meld: the in-repo copy if run from a checkout, else the installed
## /usr/bin/git-meld.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

mydir="$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" && pwd )"
## Test payload directory: installed share dir, or the in-repo path when running
## from a dist-ai checkout.
if [ -d "/usr/share/git-meld-tests" ]; then
   share="/usr/share/git-meld-tests"
else
   share="${mydir}/../share/git-meld-tests"
fi
## Adversarial suites to run (NOT the fuzzer -- that has its own runner):
##  - adversarial-lib.sh: direct-invocation, submodule hidden-change.
##  - adversarial-comprehensive-lib.sh: real 'git diff' covering mode-only,
##    symlink, gitlink-content spoof, Trojan-Source Unicode, and files git
##    skips (binary/.gitattributes) via the re-dispatch pre-flight.
adversarial_libs=(
   "${share}/adversarial-lib.sh"
   "${share}/adversarial-comprehensive-lib.sh"
)

git_meld="${1:-}"
if [ -z "${git_meld}" ]; then
   for cand in \
      "${mydir}/../../derivative-maker/packages/kicksecure/developer-meta-files/usr/bin/git-meld" \
      "/usr/bin/git-meld" ; do
      if [ -x "${cand}" ]; then git_meld="${cand}"; break; fi
   done
fi
if [ -z "${git_meld}" ] || [ ! -x "${git_meld}" ]; then
   printf '%s\n' "ERROR: git-meld not found; pass it as arg 1." >&2
   exit 2
fi

printf '%s\n' "== git-meld-tests: adversarial hidden-change suites =="
printf '%s\n' "git-meld under test: ${git_meld}"

run_suites () {
   ## Run every adversarial suite against $1, letting each suite's per-case
   ## output through to stdout, and store the summed failure count (each suite
   ## exits with its own count) in the global run_suites_total. The count is
   ## returned via that global, NOT via stdout, on purpose: the suites print
   ## their diagnostics to stdout, so a stdout-carried count would be
   ## concatenated with all of it under command substitution and never compare
   ## equal to 0 -- which made the runner always report a failure.
   local target="$1" total=0 rc
   local suite
   for suite in "${adversarial_libs[@]}"; do
      rc=0
      bash "${suite}" "${target}" || rc=$?
      total=$((total + rc))
   done
   run_suites_total="${total}"
}

## Optional: demonstrate the OLD (pre-fix) code HID changes, if a ref is given
## and we are inside the developer-meta-files repo.
if [ -n "${GIT_MELD_OLD_REF:-}" ]; then
   dmf_repo="$(dirname -- "${git_meld}")/../"
   old_copy="$(mktemp)"
   if git -C "${dmf_repo}" show "${GIT_MELD_OLD_REF}:usr/bin/git-meld" > "${old_copy}" 2>/dev/null; then
      chmod +x "${old_copy}"
      printf '\n%s\n' "-- OLD code (${GIT_MELD_OLD_REF}): expected to HIDE changes (non-zero total) --"
      run_suites "${old_copy}"
      old_fails="${run_suites_total}"
      printf '%s\n' "OLD hidden-change failures: ${old_fails} (non-zero == the bug reproduced)"
   fi
   rm -f "${old_copy}"
fi

printf '\n%s\n' "-- CURRENT code: expected 0 hidden-change failures --"
run_suites "${git_meld}"
new_fails="${run_suites_total}"
if [ "${new_fails}" != 0 ]; then
   printf '%s\n' "FAIL: git-meld hid ${new_fails} real change(s) -- a review tool must never do that." >&2
   exit 1
fi
printf '%s\n' "PASS: no real change was hidden across all adversarial suites."
