#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Coverage gate for secure-terminal. Runs the Qt-free core suite plus the
## hypothesis property suite under coverage.py and ENFORCES 100% line coverage
## of the security-critical sanitizer (sanitize.py) - the escape-stripping,
## paste-sanitising, SGR/line-edit render core that everything else depends on.
## The overall package coverage (GUI included) is reported for information but
## not hard-gated here: raising the whole PyQt application to 100% is a ratchet,
## and gaming it with blanket exclusions would defeat the point. A failure here
## means a line of the sanitizer became unreachable by the tests - add a test.
##
## SKIPs (exit 77) when secure_terminal or python3-coverage is unavailable.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-tests' ]; then
   tests_dir='/usr/share/secure-terminal-tests'
else
   tests_dir="${script_dir}/../share/secure-terminal-tests"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-tests-coverage: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

if ! python3 -c 'import coverage' 2>/dev/null; then
   printf 'secure-terminal-tests-coverage: SKIP (python3-coverage not installed)\n' >&2
   exit 77
fi

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"
pkg="${repo}/usr/lib/python3/dist-packages/secure_terminal"

work="$(mktemp --directory)"
cleanup() { rm -r -f -- "${work}" 2>/dev/null || true; }
trap cleanup EXIT
export COVERAGE_FILE="${work}/.coverage"

## these two suites together exercise the whole sanitizer, and run headless-free
## except for the offscreen Qt platform the property suite touches.
export QT_QPA_PLATFORM=offscreen
python3 -m coverage erase
for suite in test_secure_terminal test_fuzz; do
   python3 -m coverage run --append --source="${pkg}" -- "${tests_dir}/${suite}.py"
done

printf '\n== sanitizer coverage (gated at 100%%) ==\n'
## hard gate: the security-critical sanitizer must be fully covered.
python3 -m coverage report --include='*/sanitize.py' --show-missing --fail-under=100

printf '\n== whole-package coverage (reported, not gated) ==\n'
python3 -m coverage report || true
