#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Coverage gate for secure-terminal. Runs every test suite under coverage.py
## and ENFORCES 100% line coverage on the whole package -- both the Qt-free core
## (sanitizer, CLI wrapper, command-hook protocol, IPC framing, session
## persistence, drop-in settings) and the Qt GUI (dialog, terminal, main). A
## failure here means a line became unreachable by the tests -- add a test (do
## not paper over it with a blanket exclusion; the few genuinely-unreachable
## defensive/optional-dependency lines carry a justified `# pragma: no cover` in
## the source instead).
##
## SKIPs (exit 77) when secure_terminal or python3-coverage is unavailable.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-tests' ]; then
   tests_dir='/usr/share/secure-terminal-tests'
else
   tests_dir="${script_dir}/../share/secure-terminal-tests"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-tests-coverage: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

if ! python3 -c 'import coverage' 2>/dev/null; then
   printf 'secure-terminal-tests-coverage: SKIP (python3-coverage not installed)\n' >&2
   exit 77
fi

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"
pkg="${repo}/usr/lib/python3/dist-packages/secure_terminal"

work="$(mktemp --directory)"
cleanup() { rm -r -f -- "${work}" 2>/dev/null || true; }
trap cleanup EXIT
export COVERAGE_FILE="${work}/.coverage"

## Run every suite under coverage. --parallel-mode + combine keeps each suite's
## (and any forked child's) data in its own file, then merges them. test_widget
## needs the offscreen Qt platform and SKIPs (exit 77) when PyQt6/pyte are
## absent; the GATED modules below are all covered by the Qt-FREE suites, so the
## hard gate stays green even on a headless box without Qt.
export QT_QPA_PLATFORM=offscreen
python3 -m coverage erase
qt_ran=0
for suite in test_secure_terminal test_fuzz test_corpus test_cli test_modules \
             test_review test_mainwin test_widget; do
   [ -f "${tests_dir}/${suite}.py" ] || continue
   rc=0
   python3 -m coverage run --parallel-mode --source="${pkg}" -- \
      "${tests_dir}/${suite}.py" || rc="$?"
   ## exit 77 (SKIP, e.g. Qt absent for a widget suite) is not a failure here;
   ## the Qt-free gated tier does not depend on those suites. Any other non-zero
   ## is fatal.
   if [ "${rc}" != '0' ] && [ "${rc}" != '77' ]; then
      printf 'secure-terminal-tests-coverage: suite %s failed (exit %s)\n' \
         "${suite}" "${rc}" >&2
      exit "${rc}"
   fi
   ## the Qt tier is gated only when its suite actually ran (Qt present).
   if [ "${suite}" = 'test_review' ] && [ "${rc}" = '0' ]; then
      qt_ran=1
   fi
done
python3 -m coverage combine

## Ratchet-gated modules, in two tiers. As a module reaches full coverage it is
## added here so coverage can only go up. Each is genuinely 100% -- the few
## unreachable defensive lines (post-fork/pre-exec, EINTR retries) carry a
## justified `# pragma: no cover` in the source, not a blanket exclusion.
##
## Tier 1 -- covered by the Qt-FREE suites, so gated on every box (Qt or not).
gated_free='*/__init__.py,*/sanitize.py,*/cli.py,*/hook.py,*/ipc.py,*/session.py,*/settings.py'
## Tier 2 -- needs the offscreen Qt widget suite; gated only when it actually ran
## (skipped when PyQt6/pyte are absent, so as not to fail a headless box).
gated_qt='*/dialog.py,*/terminal.py,*/main.py'

printf '\n== gated modules, Qt-free (must be 100%%) ==\n'
python3 -m coverage report --include="${gated_free}" --show-missing --fail-under=100

if [ "${qt_ran}" = '1' ]; then
   printf '\n== gated modules, Qt widget (must be 100%%) ==\n'
   python3 -m coverage report --include="${gated_qt}" --show-missing --fail-under=100
else
   printf '\n== Qt widget modules NOT gated (widget suites skipped; Qt absent) ==\n'
fi

printf '\n== whole-package coverage ==\n'
python3 -m coverage report || true
