#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy fuzz run of check-ref-commits-for-unicode: same harness as
## check-ref-commits-for-unicode-tests with a larger default iteration count.
## Each iteration builds a real commit whose payload is clean or carries a
## suspicious character in a random location, and asserts the tool's exit agrees
## with an independent oracle and its output stays pure ASCII. Because every
## iteration builds a git commit, this is heavier per iteration than the
## byte-level sibling suites. Override with --iterations N / --seed N. See
## check-ref-commits-for-unicode-tests for the checks and the
## CHECK_REF_COMMITS_REPO override.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/check-ref-commits-for-unicode-tests' ]; then
   tests_dir='/usr/share/check-ref-commits-for-unicode-tests'
else
   tests_dir="${script_dir}/../share/check-ref-commits-for-unicode-tests"
fi

iterations='1000'

exec python3 -- "${tests_dir}/check_ref_commits_for_unicode_test.py" \
   --fuzz-only --iterations "${iterations}" "$@"
