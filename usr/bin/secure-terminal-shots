#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Single entry point for ALL of the secure-terminal.github.io screenshots. The
## generators live together in usr/share/secure-terminal-shots/ (see its README).
##
## Usage: secure-terminal-shots [review|comparison|comparison-wayland] [ARGS...]
##
##   review      (default) the paste + copy REVIEW-BAR shots -- headless, offscreen
##               Qt grab of the real ReviewBar, deterministic. OUTPUT_DIR defaults
##               to the site's shots/. This is the safe, no-display path.
##   comparison  the terminal-COMPARISON shots -- real Debian terminal emulators
##               under a nested labwc compositor (X11 clients). NEEDS an X server +
##               labwc; run it in a sandbox. Writes to its own shots/; copy them to
##               the site's comparison/shots/. Forwards ST_REPO etc.
##   comparison-wayland  the same comparison, but the terminals run as NATIVE
##               WAYLAND clients (X11-only ones via labwc's Xwayland) and grim
##               captures. Runs inside its own net+mount namespace. Extra args pass
##               through: --all-terminals (default) / --wayland-terminals /
##               --x11-terminals / --only NAME / --case C / --quick / --settle S.
##
## Both target a secure-terminal checkout resolved from SECURE_TERMINAL_REPO (or a
## default under the operator's private-sources); SKIPs (exit 77) if it is absent.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-shots' ]; then
   shots_dir='/usr/share/secure-terminal-shots'
else
   shots_dir="${script_dir}/../share/secure-terminal-shots"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-shots: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

mode='review'
if [ "$#" -ge 1 ] && { [ "$1" = 'review' ] || [ "$1" = 'comparison' ] \
      || [ "$1" = 'comparison-wayland' ]; }; then
   mode="$1"
   shift
fi

export SECURE_TERMINAL_REPO="${repo}"

if [ "${mode}" = 'comparison' ]; then
   ## Real-terminal comparison capture; it resolves ST_REPO / SECURE_TERMINAL_REPO
   ## itself and writes to its own shots/. Needs a display -- fails loudly if none.
   ST_REPO="${repo}" exec "${shots_dir}/comparison-capture.sh" "$@"
fi

if [ "${mode}" = 'comparison-wayland' ]; then
   ## Native-Wayland comparison capture (labwc X11-backend + native Wayland clients
   ## + grim), run inside its own net+mount namespace. Extra args pass through.
   ST_REPO="${repo}" exec "${shots_dir}/wayland-capture.sh" "$@"
fi

## review mode: headless review-bar shots into the site's shots/.
out_dir="${1:-${HOME}/private-sources/secure-terminal.github.io/shots}"
if [ ! -d "${out_dir}" ]; then
   printf 'secure-terminal-shots: output dir does not exist: %s\n' "${out_dir}" >&2
   exit 1
fi

shot_script="${shots_dir}/paste-warning-shot.py"
if [ ! -f "${shot_script}" ]; then
   printf 'secure-terminal-shots: shot generator missing: %s\n' "${shot_script}" >&2
   exit 1
fi

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"

## One entry per shot: <kind> <output-file>. Add a line here to grow the set.
for spec in \
   'paste paste-warning.png' \
   'copy copy-warning.png'; do
   read -r kind file <<< "${spec}"
   python3 -- "${shot_script}" "${out_dir}/${file}" "${kind}"
done

printf 'secure-terminal-shots: wrote paste-warning.png + copy-warning.png to %s\n' "${out_dir}"
