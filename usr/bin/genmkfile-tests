#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## Runs the genmkfile dispatch regression suite: it drives the real
## genmkfile against a throwaway minimal Debian source package and
## asserts that deb-cleanup and reprepro-{remove,add} are routed through
## make_get_variables (not the cheap dependencies-only path), guarding
## the fix for the "make_upstream_tarball_relative_path: unbound
## variable" abort. No root, no network, no real reprepro. Works
## installed (tests under /usr/share/genmkfile-tests) or from a git
## checkout. Set GENMKFILE_BIN to pick the genmkfile under test;
## otherwise the suite uses genmkfile from PATH, then a derivative-maker
## checkout under ~/derivative-maker.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/genmkfile-tests' ]; then
   tests_dir='/usr/share/genmkfile-tests'
else
   tests_dir="${script_dir}/../share/genmkfile-tests"
fi

## Run every *_test.sh in the suite. Exit 77 from a test means SKIP
## (missing genmkfile / tooling) and does not count as a failure; any
## other non-zero exit is a failure. Overall exit is non-zero iff at
## least one test failed.
shopt -s nullglob
failures=0
ran=0
for test_script in "${tests_dir}"/*_test.sh; do
  ran=$(( ran + 1 ))
  printf '\n########## %s ##########\n' "$(basename -- "${test_script}")"
  rc=0
  bash -- "${test_script}" "$@" || rc=$?
  if [ "${rc}" -eq 77 ]; then
    printf '########## SKIPPED: %s ##########\n' "$(basename -- "${test_script}")"
  elif [ "${rc}" -ne 0 ]; then
    printf '########## FAILED (%s): %s ##########\n' "${rc}" "$(basename -- "${test_script}")"
    failures=$(( failures + 1 ))
  fi
done

if [ "${ran}" -eq 0 ]; then
  printf 'ERROR: no *_test.sh found in %s\n' "${tests_dir}" >&2
  exit 1
fi
if [ "${failures}" -ne 0 ]; then
  printf '\nFAILED: %s genmkfile test script(s) failed\n' "${failures}" >&2
  exit 1
fi
printf '\nOK: all genmkfile test scripts passed\n'
exit 0
