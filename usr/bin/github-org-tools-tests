#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Runs developer-meta-files' github-org-tools mock-API test suite: drives the
## dm-github-* / github-org-* tools against canned fixtures (no real GitHub
## access), covering arg parsing, validator behaviour, mock-dispatch routing,
## rate-limit retry math, and the audit / dry-run output shape.
##
## Checkout-based: the tools resolve their own libexec libs via
## DEVELOPER_META_FILES_PATH and helper-scripts via HELPER_SCRIPTS_PATH (both
## wired by dist-ai-tests-all from --component developer-meta-files). Needs the
## developer-meta-files + helper-scripts checkouts; exits 77 (SKIP) if either
## (or sanitize-string) is absent. Works installed (/usr/share/...) or from a
## checkout.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/github-org-tools-tests' ]; then
   share='/usr/share/github-org-tools-tests'
else
   share="${script_dir}/../share/github-org-tools-tests"
fi

if [ -z "${DEVELOPER_META_FILES_PATH:-}" ]; then
   printf '%s\n' 'github-org-tools-tests: DEVELOPER_META_FILES_PATH unset (run with --component developer-meta-files --component-root DIR); skipping.' >&2
   exit 77
fi
if [ ! -x "${DEVELOPER_META_FILES_PATH}/usr/bin/dm-github-org-policy" ]; then
   printf '%s\n' "github-org-tools-tests: '${DEVELOPER_META_FILES_PATH}/usr/bin/dm-github-org-policy' not found; skipping." >&2
   exit 77
fi
if [ -z "${HELPER_SCRIPTS_PATH:-}" ] || [ ! -x "${HELPER_SCRIPTS_PATH}/usr/bin/sanitize-string" ]; then
   printf '%s\n' 'github-org-tools-tests: helper-scripts (sanitize-string) checkout not available; skipping.' >&2
   exit 77
fi

## Env the runner + tools need: the tools on PATH (dm-github-* resolve their
## libexec via DEVELOPER_META_FILES_PATH), sanitize-string + friends on PATH,
## its library on PYTHONPATH (sanitize-string's '-Bsu' shebang excludes the
## user site), and CI=true to acknowledge that the suite mutates a local
## sandbox. Both *_PATH vars are already exported by the caller.
export CI='true'
export PATH="${DEVELOPER_META_FILES_PATH}/usr/bin:${HELPER_SCRIPTS_PATH}/usr/bin:${PATH}"
export PYTHONPATH="${HELPER_SCRIPTS_PATH}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"

## Run the runner as a child and forward its exit code (no process-replacing
## exec).
rc=0
"${share}/test-github-org-tools.sh" "$@" || rc="$?"
exit "$rc"
