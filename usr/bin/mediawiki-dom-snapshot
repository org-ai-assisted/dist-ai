#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## CLI wrapper for the mediawiki-dom-snapshot tool. Dispatches to one of
##   capture   - hit pages, dump raw HTML
##   normalise - rewrite raw -> stable fixtures
##   diff      - compare two fixture sets
##   run       - capture + normalise in one go (default)
##
## Environment overrides (forwarded as-is to the Python helpers):
##   BASE_URL      target wiki origin    (default https://www.kicksecure.com)
##   PAGES_FILE    page list             (default /etc/mediawiki-dom-snapshot/pages.conf)
##   VIEWPORT      browser viewport      (default 1280x800)
##   TIMEOUT_MS    per-page timeout      (default 30000)
##   RAW_DIR       raw output dir        (default /var/lib/mediawiki-dom-snapshot/raw)
##   FIX_DIR       normalised output dir (default /var/lib/mediawiki-dom-snapshot/fixtures)

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

readonly LIB=/usr/share/mediawiki-dom-snapshot
[ -v PAGES_FILE ] || PAGES_FILE=/etc/mediawiki-dom-snapshot/pages.conf
[ -v BASE_URL ]   || BASE_URL=https://www.kicksecure.com
[ -v VIEWPORT ]   || VIEWPORT=1280x800
[ -v TIMEOUT_MS ] || TIMEOUT_MS=30000
[ -v RAW_DIR ]    || RAW_DIR=/var/lib/mediawiki-dom-snapshot/raw
[ -v FIX_DIR ]    || FIX_DIR=/var/lib/mediawiki-dom-snapshot/fixtures
export BASE_URL VIEWPORT TIMEOUT_MS PAGES_FILE RAW_DIR

usage() {
   cat >&2 <<EOF
usage: ${0##*/} [capture|normalise|run|diff <a> <b>|baseline-promote <tag>]

  capture            run Playwright against \$BASE_URL, dump HTML to \$RAW_DIR
  normalise          rewrite \$RAW_DIR/*.html -> \$FIX_DIR/*.html (stable diff form)
  run                capture + normalise (default)
  diff <a> <b>       diff -ur \$FIX_DIR/<a>/ \$FIX_DIR/<b>/
  baseline-promote <tag>
                     promote \$FIX_DIR/<tag>/ to /usr/share/mediawiki-dom-snapshot/baseline/

env: BASE_URL PAGES_FILE VIEWPORT TIMEOUT_MS RAW_DIR FIX_DIR
EOF
}

cmd_capture() {
   mkdir --parents -- "${RAW_DIR}"
   exec python3 "${LIB}/snapshot.py"
}

cmd_normalise() {
   mkdir --parents -- "${FIX_DIR}"
   shopt -s nullglob
   for f in "${RAW_DIR}"/*.html; do
      python3 "${LIB}/normalize.py" "${f}" "${FIX_DIR}/$(basename "${f}")"
   done
}

cmd_run() {
   cmd_capture
   cmd_normalise
}

cmd_diff() {
   [ "$#" -eq 2 ] || { usage; exit 2; }
   exec diff --unified --recursive -- "${FIX_DIR}/$1" "${FIX_DIR}/$2"
}

cmd_baseline_promote() {
   [ "$#" -eq 1 ] || { usage; exit 2; }
   local src="${FIX_DIR}/$1"
   local dst=/usr/share/mediawiki-dom-snapshot/baseline
   [ -d "${src}" ] || { printf '%s\n' "${0##*/}: missing ${src}" >&2; exit 1; }
   mkdir --parents -- "${dst}"
   cp --recursive --no-target-directory -- "${src}" "${dst}"
   printf '%s\n' "promoted ${src} -> ${dst}"
}

case "${1:-run}" in
   capture)          shift; cmd_capture "$@" ;;
   normalise)        shift; cmd_normalise "$@" ;;
   run|"")           shift || true; cmd_run "$@" ;;
   diff)             shift; cmd_diff "$@" ;;
   baseline-promote) shift; cmd_baseline_promote "$@" ;;
   -h|--help|help)   usage; exit 0 ;;
   *)                printf '%s\n' "${0##*/}: unknown command: $1" >&2; usage; exit 2 ;;
esac
