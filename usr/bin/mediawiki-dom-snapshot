#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## CLI wrapper for the mediawiki-dom-snapshot tool. Dispatches to one of
##   capture           Playwright capture: dom.html + screenshot.png +
##                     manifest.json + assets/<sha256>.<ext>
##   normalise         rewrite raw -> stable fixtures (URL scrub etc.)
##   run               capture + normalise (default)
##   diff <a> <b>      three-axis diff: HTML, asset manifest, screenshot
##                     pixels + pHash
##   diff-baseline <t> diff the shipped baseline against fixtures/<t>/
##   baseline-promote <tag>
##                     promote fixtures/<tag> to the shipped baseline at
##                     /usr/share/mediawiki-dom-snapshot/baseline/
##
## Environment overrides:
##   BASE_URL       target wiki origin    (default https://www.kicksecure.com)
##   PAGES_FILE     page list             (default /etc/mediawiki-dom-snapshot/pages.conf)
##   VIEWPORT       legacy single-viewport hint (mode dim VP supersedes)
##   TIMEOUT_MS     per-page timeout      (default 30000)
##   CONCURRENCY    parallel captures     (default 4)
##   RAW_DIR        raw output dir        (default /var/lib/mediawiki-dom-snapshot/raw)
##   FIX_DIR        normalised output dir (default /var/lib/mediawiki-dom-snapshot/fixtures)
##   CAPTURE_MODES  comma-separated mode labels, or "all" (default).
##                  Mode label syntax:
##                    <auth>-<visit>-<vp>-<scheme>-<intent>-<browser>[-locale-XX]
##                    auth     anon | user | admin
##                    visit    first | repeat
##                    vp       desktop | mobile
##                    scheme   light | dark | print
##                    intent   view | edit | search | postedit | hover
##                    browser  chromium | firefox | webkit
##   BROWSERS       comma-separated subset of chromium,firefox,webkit
##                  or "all"            (default chromium)
##   LOCALES        comma-separated BCP47 locales (default en).
##                  Non-default locales only generate captures of the
##                  canonical anon-first-desktop-light-view-chromium
##                  combination per locale.
##   WIKI_USER      username for auth=user modes (must be paired with
##                  WIKI_PASSWORD; if unset, user-* modes are skipped)
##   WIKI_PASSWORD  password for auth=user modes
##   ADMIN_USER     username for auth=admin modes (must be paired with
##                  ADMIN_PASSWORD; if unset, admin-* modes are skipped)
##   ADMIN_PASSWORD password for auth=admin modes
##   POSTEDIT_PAGES comma-separated wiki page titles eligible for the
##                  postedit intent (edits + saves the page, captures
##                  the result, reverts). Empty default = skip every
##                  page; export to opt in.
##   CONCURRENCY    parallel captures per snapshot run (default 4 in
##                  snapshot.py). Higher values fan more browser
##                  contexts at the wiki backend; reasonable range is
##                  4-12 depending on backend headroom.
##   NORMALISE_JOBS parallel worker count for the normalise step
##                  (default 8). Per-page directories are scrubbed
##                  independently so wallclock scales linearly with
##                  worker count up to CPU saturation.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

readonly LIB=/usr/share/mediawiki-dom-snapshot
[ -v PAGES_FILE ] || PAGES_FILE=/etc/mediawiki-dom-snapshot/pages.conf
[ -v BASE_URL ]   || BASE_URL=https://www.kicksecure.com
[ -v VIEWPORT ]   || VIEWPORT=1280x800
[ -v TIMEOUT_MS ] || TIMEOUT_MS=30000
[ -v RAW_DIR ]    || RAW_DIR=/var/lib/mediawiki-dom-snapshot/raw
[ -v FIX_DIR ]    || FIX_DIR=/var/lib/mediawiki-dom-snapshot/fixtures
export BASE_URL VIEWPORT TIMEOUT_MS PAGES_FILE RAW_DIR

readonly BASELINE_DIR=/usr/share/mediawiki-dom-snapshot/baseline

usage() {
   cat >&2 <<EOF
usage: ${0##*/} [capture|normalise|run|diff <a> <b>|diff-baseline <tag>|baseline-promote <tag>] [--brief]

  capture            run Playwright against \$BASE_URL, dump per-page
                     directories under \$RAW_DIR with dom.html +
                     screenshot.png + manifest.json + assets/.
  normalise          rewrite each \$RAW_DIR/<page>/ -> \$FIX_DIR/<page>/
                     scrubbing per-request volatility.
  run                capture + normalise (default)
  diff <a> <b>       three-axis diff: HTML, asset manifest, screenshot
                     pixels + pHash. Operates on \$FIX_DIR/<a> and
                     \$FIX_DIR/<b>. Pass --brief to suppress the per-
                     asset body diff.
  diff-baseline <tag>
                     diff \$BASELINE_DIR against \$FIX_DIR/<tag>.
  baseline-promote <tag>
                     replace \$BASELINE_DIR with \$FIX_DIR/<tag>.

env: BASE_URL PAGES_FILE VIEWPORT TIMEOUT_MS RAW_DIR FIX_DIR
EOF
}

cmd_capture() {
   mkdir --parents -- "${RAW_DIR}"
   exec python3 "${LIB}/snapshot.py"
}

cmd_normalise() {
   mkdir --parents -- "${FIX_DIR}"
   shopt -s nullglob
   ## Each per-page directory is independent so we normalise them in
   ## parallel. NORMALISE_JOBS bounds the worker count; default 8 is
   ## comfortable on a developer laptop and matches snapshot.py's
   ## CONCURRENCY default ballpark.
   local -i jobs="${NORMALISE_JOBS:-8}"
   find "${RAW_DIR}" -mindepth 1 -maxdepth 1 -type d -print0 \
      | xargs -0 -P "${jobs}" -I {} sh -c '
            page=$(basename "$1")
            python3 "$2" "$1" "$3/$page"
         ' _ {} "${LIB}/normalize.py" "${FIX_DIR}"
}

cmd_run() {
   cmd_capture
   cmd_normalise
}

cmd_diff() {
   [ "$#" -ge 2 ] || { usage; exit 2; }
   local a="$1"; shift
   local b="$1"; shift
   exec python3 "${LIB}/diff.py" "${FIX_DIR}/${a}" "${FIX_DIR}/${b}" "$@"
}

cmd_diff_baseline() {
   [ "$#" -ge 1 ] || { usage; exit 2; }
   local tag="$1"; shift
   exec python3 "${LIB}/diff.py" "${BASELINE_DIR}" "${FIX_DIR}/${tag}" "$@"
}

cmd_baseline_promote() {
   [ "$#" -eq 1 ] || { usage; exit 2; }
   local src="${FIX_DIR}/$1"
   [ -d "${src}" ] || { printf '%s\n' "${0##*/}: missing ${src}" >&2; exit 1; }
   rm --recursive --force -- "${BASELINE_DIR}"
   mkdir --parents -- "${BASELINE_DIR}"
   cp --recursive --no-target-directory -- "${src}" "${BASELINE_DIR}"
   printf '%s\n' "promoted ${src} -> ${BASELINE_DIR}"
}

case "${1:-run}" in
   capture)          shift; cmd_capture "$@" ;;
   normalise)        shift; cmd_normalise "$@" ;;
   run|"")           shift || true; cmd_run "$@" ;;
   diff)             shift; cmd_diff "$@" ;;
   diff-baseline)    shift; cmd_diff_baseline "$@" ;;
   baseline-promote) shift; cmd_baseline_promote "$@" ;;
   -h|--help|help)   usage; exit 0 ;;
   *)                printf '%s\n' "${0##*/}: unknown command: $1" >&2; usage; exit 2 ;;
esac
