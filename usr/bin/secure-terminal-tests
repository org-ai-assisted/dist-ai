#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Tests for secure-terminal's pure, Qt-free sanitization core
## (secure-terminal: usr/lib/python3/dist-packages/secure_terminal/sanitize.py):
## the display-mode renderer (strip/show/reveal), paste sanitization and
## classification, the safe-colour SGR parser and its contrast guard, and the
## NO_COLOR / TERM=dumb environment handling, plus a static check that the widget
## layer never routes untrusted text into an HTML sink. The core has no GUI
## dependency, so this runs it directly under python3 with no PyQt6. No root, no
## network. It targets a secure-terminal checkout resolved from
## SECURE_TERMINAL_REPO (or a default under the operator's private-sources); if
## the module cannot be found it SKIPs (exit 77) rather than failing.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-tests' ]; then
   tests_dir='/usr/share/secure-terminal-tests'
else
   tests_dir="${script_dir}/../share/secure-terminal-tests"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-tests: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

## No interpreter check: a missing python3 is a hard FAIL, not a SKIP -- the
## tests below invoke python3 directly and fail loudly if it is absent
## (security by default: a test dependency that is missing must not be silently
## skipped). The only SKIP is a genuinely absent target checkout (above).

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"

## The pure, Qt-free tests always run; the widget tests (test_widget.py) skip
## themselves (exit 77) when PyQt6/pyte are absent. The suite fails if any test
## fails, and SKIPs only when the pure test cannot import the module at all.
overall=0
for test_file in \
   "${tests_dir}/test_secure_terminal.py" \
   "${tests_dir}/test_fuzz.py" \
   "${tests_dir}/test_corpus.py" \
   "${tests_dir}/test_widget.py"; do
   [ -f "${test_file}" ] || continue
   if python3 -Bsu -- "${test_file}" "$@"; then
      continue
   fi
   rc="$?"
   if [ "${rc}" = '77' ]; then
      ## a SKIP from the pure test means the module is missing -> skip all
      if [ "${test_file}" = "${tests_dir}/test_secure_terminal.py" ]; then
         exit 77
      fi
      continue
   fi
   overall=1
done
exit "${overall}"
