#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy fuzz run of grep-find-unicode-wrapper: same harness as
## grep-find-unicode-wrapper-tests with a large default iteration count. Each
## iteration writes a random byte file and asserts the wrapper's match/no-match
## exit agrees with an independent byte-level oracle and that the output stays
## pure ASCII. Override with --iterations N / --seed N. See
## grep-find-unicode-wrapper-tests for the checks and the
## GREP_FIND_UNICODE_WRAPPER_REPO override.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/grep-find-unicode-wrapper-tests' ]; then
   tests_dir='/usr/share/grep-find-unicode-wrapper-tests'
else
   tests_dir="${script_dir}/../share/grep-find-unicode-wrapper-tests"
fi

iterations='5000'

exec python3 -- "${tests_dir}/grep_find_unicode_wrapper_test.py" \
   --fuzz-only --iterations "${iterations}" "$@"
