#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy randomized GUI fuzz run: drives the LIVE SecureTerminal widget (offscreen
## Qt) with adversarial escape/C1/unicode/combining-mark output, mode switches,
## pastes and key events, asserting the terminal never crashes, freezes (a per-feed
## wall-clock bound catches a Zalgo reshape DoS), leaks a control byte into the
## document, or lets a dangerous byte reach the pty on a paste. Complements the
## Qt-free parser fuzz (secure-terminal-tests-fuzz). Override with --iterations N /
## --seed N / --phase NAME; a failure prints the seed to replay. Same target
## resolution and SECURE_TERMINAL_REPO override as secure-terminal-tests; a missing
## checkout or absent PyQt6/pyte SKIPs (exit 77) rather than failing.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/secure-terminal-tests' ]; then
   tests_dir='/usr/share/secure-terminal-tests'
else
   tests_dir="${script_dir}/../share/secure-terminal-tests"
fi

repo=''
[ -v SECURE_TERMINAL_REPO ] || SECURE_TERMINAL_REPO=''
if [ -n "${SECURE_TERMINAL_REPO}" ]; then
   repo="${SECURE_TERMINAL_REPO}"
elif [ -d "${HOME}/private-sources/secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${HOME}/private-sources/secure-terminal"
elif [ -d "${script_dir}/../../../../secure-terminal/usr/lib/python3/dist-packages/secure_terminal" ]; then
   repo="${script_dir}/../../../../secure-terminal"
fi

if [ -z "${repo}" ] || [ ! -d "${repo}/usr/lib/python3/dist-packages/secure_terminal" ]; then
   printf 'secure-terminal-tests-fuzz-gui: SKIP (secure_terminal not found; set SECURE_TERMINAL_REPO)\n' >&2
   exit 77
fi

export PYTHONPATH="${repo}/usr/lib/python3/dist-packages${PYTHONPATH:+:${PYTHONPATH}}"
## The live widget needs a Qt platform; offscreen keeps it headless.
[ -v QT_QPA_PLATFORM ] || export QT_QPA_PLATFORM=offscreen

iterations='6000'

## Run the fuzzer as a child and forward its exit code (no exec / process
## replacement). errexit propagates a non-zero status as this script's own.
python3 -Bsu -- "${tests_dir}/fuzz_widget.py" \
   --iterations "${iterations}" "$@"
