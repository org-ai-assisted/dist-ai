#!/bin/bash

## Copyright (C) 2026 - 2026 ENCRYPTED SUPPORT LLC <adrelanos@whonix.org>
## See the file COPYING for copying conditions.

## AI-Assisted

## Heavy fuzz run of the sanitize family: same harness as sanitize-string-tests
## but with a large default iteration count for a longer adversarial sweep.
## Override with --iterations N / --seed N. See sanitize-string-tests for the
## checks performed and the SANITIZE_STRING_BIN override.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

script_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"

if [ -d '/usr/share/sanitize-string-tests' ]; then
   tests_dir='/usr/share/sanitize-string-tests'
else
   tests_dir="${script_dir}/../share/sanitize-string-tests"
fi

iterations='50000'

rc=0
python3 -- "${tests_dir}/sanitize_family_test.py" \
   --fuzz-only --iterations "${iterations}" "$@" || rc=$?
exit "$rc"
