## AI-Assisted

## dm-qemu: boot a built derivative-maker artifact headless over the serial console in qemu,
## for automated boot-testing (e.g. CI smoke test).
##
## Two artifact kinds are supported:
##   --iso PATH   an installer/live ISO, attached as an emulated external USB stick
##                (usb-storage), matching how users actually install it -- write to a USB stick,
##                boot from it -- rather than an optical -cdrom almost nobody uses now; this also
##                works uniformly on amd64 and arm64.
##   --disk PATH  a VM disk image (qcow2, raw, vdi, vmdk), booted from the virtual disk through
##                firmware exactly as a real VM would. The format is auto-detected with 'qemu-img
##                info' (override with --disk-format). The image is booted with qemu '-snapshot'
##                so all guest writes go to a throwaway overlay and the built artifact is never
##                modified. .ova is NOT accepted directly -- it is a tar container; extract its
##                .vmdk/.vdi and pass that.
##
## DEFAULT boot: through real firmware (SeaBIOS/OVMF on x86, edk2 UEFI on arm64) -> (shim ->)
## GRUB -> kernel, over serial. The live/VM boot is deliberately SILENT in production
## ('quiet loglevel=0'), so a plain firmware boot over serial would show GRUB and then nothing.
## dm-qemu therefore INJECTS the serial-console + verbose kernel parameters through the full
## firmware -> GRUB -> kernel chain via the SMBIOS Type 1 system serial number ('dm-cmdline=...'),
## which a cooperating grub.cfg reader (shipped in vm-config-dist) appends to the kernel line.
## This surfaces kernel + systemd + the serial getty login prompt WITHOUT editing the image and
## WITHOUT a build-time serial console -- the smbios grub module is in Debian's SIGNED grub, so it
## works on BIOS, EFI, and EFI+Secure-Boot alike.
##
## --direct-kernel is a NON-default, internal-debugging path (ISO only): it extracts the kernel,
## initrd and the chosen menu entry's cmdline from the ISO, strips the silencers ('quiet',
## 'loglevel=0', 'splash') exactly like the debug-misc package's grub-output-verbose does, and
## DIRECT-boots the kernel (qemu -kernel/-initrd/-append) with the ISO attached as the live
## medium -- bypassing firmware and GRUB. Use it only when the firmware/SMBIOS path itself is
## under suspicion; the SMBIOS default is the fidelity path.
##
## '--fast' additionally injects 'mitigations=off' so a pure-TCG host (no KVM, e.g. a nested
## Qubes VM) reaches userspace in minutes instead of not at all; do NOT use --fast for a
## security-fidelity test. KVM is used automatically when /dev/kvm is present.
##
## style-ok: no-has -- dm-qemu is a self-contained boot-tester meant to run on a bare CI
## runner (just qemu + xorriso + bash); it deliberately does NOT source derivative-maker's
## helper-scripts, so it uses 'command -v' rather than the 'has' helper.
## style-ok: no-safe-rm -- for the same reason it must not depend on the 'safe-rm' helper; the
## only removal is its OWN mktemp workdir (a fixed, self-created path), removed with 'rm -r -f'.

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

usage() {
   cat -- <<'EOF'
Usage: dm-qemu --iso PATH [options]
       dm-qemu --disk PATH [options]

  --iso PATH          boot an ISO, attached as an emulated USB stick (mutually exclusive
                      with --disk). Required unless --disk is given.
  --disk PATH         boot a VM disk image (qcow2, raw, vdi, vmdk) from the virtual disk through
                      firmware (mutually exclusive with --iso). Booted with '-snapshot' so the
                      artifact is never modified. .ova is not accepted (tar container: extract
                      its .vmdk/.vdi first).
  --disk-format FMT   override the auto-detected disk format (qcow2|raw|vdi|vmdk). Default: auto
                      via 'qemu-img info'. Only meaningful with --disk.
  --arch ARCH         guest Debian architecture (amd64, arm64, ...; default: the host's
                      'dpkg --print-architecture'). Selects the qemu binary, machine type
                      and serial console via the shared arch map, so an arm64 artifact
                      can be boot-tested (cross-arch runs under TCG; KVM only when guest arch
                      == host arch).
  --firmware FW       x86 firmware: 'bios' (SeaBIOS, default), 'efi' (OVMF), or
                      'efi-secureboot' (OVMF secboot + Microsoft-key vars; validates Debian's
                      signed shim). Boots the real firmware -> shim -> GRUB -> kernel chain.
                      Needs the 'ovmf' package. x86 (amd64) only; arm64 already uses UEFI.
  --serial-log PATH   capture the serial console here (default: <image>.serial-boot.log)
  --timeout SECS      hard qemu time limit (default 1800)
  --direct-kernel     INTERNAL DEBUG (ISO only): extract kernel/initrd from the ISO, strip
                      'quiet'/'loglevel=0'/'splash' and DIRECT-boot the kernel, bypassing
                      firmware + GRUB. Default is a firmware boot with the verbose + serial
                      console kernel parameters injected via SMBIOS (see --smbios-append).
  --fast              also inject 'mitigations=off' for pure-TCG speed (NOT a fidelity test)
  --test-console      inject a login-free ROOT shell on the serial console (systemd
                      debug-shell + mask the login getty) and quiet the kernel log, for
                      reliable automation (no interactive user shell). Used by dm-image-test.
  --entry NAME        which live menu entry's cmdline to use for --direct-kernel:
                      user (default) | sysmaint | unrestricted
  --accel MODE        acceleration: auto (default; KVM when guest arch == host arch and
                      /dev/kvm is usable, else TCG) | kvm (force, error if unavailable) |
                      tcg (force emulation)
  --memory MB         guest RAM in MB (default 3072)
  --smp N             guest vCPUs (default 4)
  --extra-append STR  extra kernel cmdline appended in --direct-kernel mode
  --qmp PATH          add a QMP control socket ('-qmp unix:PATH,server,nowait'), so a driver
                      can graceful-shutdown the guest (system_powerdown) and read the QMP
                      SHUTDOWN event to tell a guest reboot from a poweroff -- what the serial
                      console cannot do reliably. The driver connects after qemu starts.
  --screendump DIR    FULL-CHAIN framebuffer test: boot the unmodified image through firmware
                      -> (shim ->) GRUB -> kernel and watch the GUEST SCREEN over QMP (periodic
                      PNG screendumps in DIR), deciding boot success from the framebuffer instead
                      of serial. For images that cannot be instrumented (no serial console, or a
                      sovereign/measured boot that must not be edited). Mutually exclusive with
                      --direct-kernel (which serial-boots via -kernel). Auto-creates a QMP socket
                      if --qmp is not given.
  --smbios-append STR extra kernel cmdline injected through the FULL firmware -> GRUB -> kernel
                      chain via the SMBIOS Type 1 system serial number ('dm-cmdline=STR'). On the
                      default serial boot this is APPENDED to the verbose + serial-console params
                      dm-qemu already injects; on --screendump it is the only injected payload.
                      Requires an image grub.cfg that reads it (the cooperating reader; smbios
                      module is in Debian's signed grub, so this works on BIOS, EFI, and
                      EFI+Secure Boot). Ignored under --direct-kernel (which direct-boots past
                      GRUB -- use --extra-append there).
  --emit-argv         build the qemu command (incl. --direct-kernel kernel/initrd extraction) but
                      do NOT run it: print the argv one token per line to stdout for an external
                      driver (e.g. a pexpect boot-login harness) to spawn, and leave any
                      extracted-kernel workdir in place (its path is printed to stderr; the
                      caller owns cleanup). '-serial mon:stdio' is NOT added -- the caller adds
                      whatever serial wiring it needs. Composes with --direct-kernel/--entry/--fast.
  --help, -h          this help

Exit: 0 if the serial log reached a login prompt / systemd; 5 if it booted but did not reach
login within the timeout; non-zero on a setup error. KVM (/dev/kvm) is used when available.
With --emit-argv: exit 0 after printing the argv (nothing is booted).
EOF
}

## EXIT-trap target (R-051: traps call a named function, never an inline string). Removes the
## kernel/initrd (and OVMF vars) extraction workdir; only set as the trap when NOT in --emit-argv
## mode, where the caller owns the workdir instead. 'rm' (not safe-rm) per the no-safe-rm waiver
## above. Invoked only indirectly via 'trap', hence unreachable to shellcheck (SC2317).
# shellcheck disable=SC2317
dm_qemu_cleanup_workdir() {
   rm -r -f -- "${work_dir}"
}

iso=''
disk=''
disk_format=''
serial_log=''
timeout_secs='1800'
direct_kernel='false'
fast='false'
entry='user'
memory='3072'
smp='4'
extra_append=''
emit_argv='false'
arch=''
accel='auto'
qmp=''
screendump=''
smbios_append=''
test_console=''
firmware='bios'

while [ "$#" -gt 0 ]; do
   case "$1" in
      --iso)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --iso needs a value\n' >&2; exit 2; }
         iso="${2}"
         shift 2
         ;;
      --disk)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --disk needs a value\n' >&2; exit 2; }
         disk="${2}"
         shift 2
         ;;
      --disk-format)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --disk-format needs a value\n' >&2; exit 2; }
         disk_format="${2}"
         shift 2
         ;;
      --arch)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --arch needs a value\n' >&2; exit 2; }
         arch="${2}"
         shift 2
         ;;
      --accel)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --accel needs a value\n' >&2; exit 2; }
         accel="${2}"
         shift 2
         ;;
      --firmware)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --firmware needs a value\n' >&2; exit 2; }
         firmware="${2}"
         shift 2
         ;;
      --qmp)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --qmp needs a value\n' >&2; exit 2; }
         qmp="${2}"
         shift 2
         ;;
      --screendump)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --screendump needs a value\n' >&2; exit 2; }
         screendump="${2}"
         shift 2
         ;;
      --smbios-append)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --smbios-append needs a value\n' >&2; exit 2; }
         smbios_append="${2}"
         shift 2
         ;;
      --serial-log)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --serial-log needs a value\n' >&2; exit 2; }
         serial_log="${2}"
         shift 2
         ;;
      --timeout)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --timeout needs a value\n' >&2; exit 2; }
         timeout_secs="${2}"
         shift 2
         ;;
      --direct-kernel)
         direct_kernel='true'
         shift
         ;;
      --emit-argv)
         emit_argv='true'
         shift
         ;;
      --fast)
         fast='true'
         shift
         ;;
      --test-console)
         test_console='true'
         shift
         ;;
      --entry)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --entry needs a value\n' >&2; exit 2; }
         entry="${2}"
         shift 2
         ;;
      --memory)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --memory needs a value\n' >&2; exit 2; }
         memory="${2}"
         shift 2
         ;;
      --smp)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --smp needs a value\n' >&2; exit 2; }
         smp="${2}"
         shift 2
         ;;
      --extra-append)
         [ "$#" -ge 2 ] || { printf 'dm-qemu: --extra-append needs a value\n' >&2; exit 2; }
         extra_append="${2}"
         shift 2
         ;;
      --help|-h)
         usage
         exit 0
         ;;
      --)
         shift
         break
         ;;
      -*)
         printf 'dm-qemu: unknown option: %s\n' "$1" >&2
         exit 2
         ;;
      *)
         break
         ;;
   esac
done

## Exactly one artifact: --iso or --disk.
if [ -n "${iso}" ] && [ -n "${disk}" ]; then
   printf 'dm-qemu: --iso and --disk are mutually exclusive\n' >&2
   exit 2
fi
if [ -z "${iso}" ] && [ -z "${disk}" ]; then
   printf 'dm-qemu: one of --iso or --disk is required\n' >&2
   usage >&2
   exit 2
fi
if [ -n "${iso}" ]; then
   [ -r "${iso}" ] || { printf 'dm-qemu: ISO not readable: %s\n' "${iso}" >&2; exit 2; }
   image="${iso}"
else
   [ -r "${disk}" ] || { printf 'dm-qemu: disk image not readable: %s\n' "${disk}" >&2; exit 2; }
   image="${disk}"
fi
[ -n "${serial_log}" ] || serial_log="${image}.serial-boot.log"

## --direct-kernel extracts the kernel/initrd from an ISO's /live tree; a disk image has no such
## tree to extract from, so it is ISO-only.
if [ "${direct_kernel}" = 'true' ] && [ -z "${iso}" ]; then
   printf 'dm-qemu: --direct-kernel needs --iso (it extracts kernel/initrd from the ISO); a disk image boots through firmware only\n' >&2
   exit 2
fi
## --screendump (framebuffer, full-chain) and --direct-kernel (serial '-kernel' direct boot) are
## different, incompatible boot paths.
if [ -n "${screendump}" ] && [ "${direct_kernel}" = 'true' ]; then
   printf 'dm-qemu: --screendump and --direct-kernel are mutually exclusive (framebuffer vs serial direct-boot)\n' >&2
   exit 2
fi
## --smbios-append travels through GRUB; --direct-kernel boots the kernel past GRUB, so the
## SMBIOS reader never runs. Refuse the combination loudly rather than silently dropping it
## (use --extra-append in --direct-kernel mode instead).
if [ -n "${smbios_append}" ] && [ "${direct_kernel}" = 'true' ]; then
   printf 'dm-qemu: --smbios-append needs the GRUB path; it is ignored under --direct-kernel. Use --extra-append for direct boot.\n' >&2
   exit 2
fi

## Reuse the canonical Debian-arch -> qemu machine-name map (single source of truth, shared
## with help-steps/variables) instead of re-encoding it here. The fragment is side-effect
## free (no dependency on help-steps/pre), so sourcing it drags in no build context.
dm_qemu_dir="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
# shellcheck source=arch-to-qemu-machine.bsh
source "${dm_qemu_dir}/arch-to-qemu-machine.bsh"

## Default the guest arch to the HOST's Debian architecture via 'dpkg --print-architecture' --
## the same source help-steps/variables and parse-cmd use for host_architecture -- so no
## uname->arch table is needed here. --arch takes a Debian arch (amd64, arm64, ...), matching
## dist_build_target_arch; pass it to boot-test a cross-arch artifact (arm64 on amd64 runs TCG).
host_arch="$(dpkg --print-architecture)"
[ -n "${arch}" ] || arch="${host_arch}"

## All three arch->qemu mappings come from the shared arch-to-qemu-machine.bsh fragment (single source of
## truth): the qemu binary ('qemu-system-<machine>'), the '-machine' board type, and the serial
## console device. An arch the fragment does not map is not wired for boot-testing.
guest_machine="$(dist_build_arch_to_qemu_machine "${arch}")" \
   || { printf 'dm-qemu: unsupported --arch %s\n' "${arch}" >&2; exit 2; }
qemu_bin="qemu-system-${guest_machine}"
machine="$(dist_build_arch_to_qemu_machine_type "${arch}")" \
   || { printf 'dm-qemu: boot-testing not wired for arch %s (no qemu machine type)\n' "${arch}" >&2; exit 2; }
serial_console="$(dist_build_arch_to_serial_console "${arch}")" \
   || { printf 'dm-qemu: boot-testing not wired for arch %s (no serial console)\n' "${arch}" >&2; exit 2; }

command -v "${qemu_bin}" >/dev/null || { printf 'dm-qemu: %s not installed (needed for --arch %s)\n' "${qemu_bin}" "${arch}" >&2; exit 2; }

## --firmware: bios (SeaBIOS on x86 / edk2 on arm64, the default), efi (OVMF), or efi-secureboot
## (OVMF secboot firmware + Microsoft-key vars that validate Debian's MS-signed shim). efi and
## efi-secureboot are x86 (amd64) only here; arm64 already boots via edk2 UEFI on the plain path.
case "${firmware}" in
   bios)
      ;;
   efi|efi-secureboot)
      if [ "${guest_machine}" != 'x86_64' ]; then
         printf 'dm-qemu: --firmware %s is x86 (amd64) only; arm64 already uses UEFI\n' "${firmware}" >&2
         exit 2
      fi
      ## Secure Boot requires System Management Mode; the q35 machine supports it.
      if [ "${firmware}" = 'efi-secureboot' ]; then
         machine="${machine},smm=on"
      fi
      ;;
   *)
      printf 'dm-qemu: --firmware must be bios, efi, or efi-secureboot\n' >&2
      exit 2
      ;;
esac

## Command pre-flight (R-091: once, near the top). xorriso reads the ISO for --direct-kernel;
## qemu-img auto-detects a disk image's format; ImageMagick powers --screendump. Each is checked
## only on the path that actually needs it.
if [ "${direct_kernel}" = 'true' ]; then
   command -v xorriso >/dev/null || { printf 'dm-qemu: xorriso not installed (needed to read the ISO for --direct-kernel)\n' >&2; exit 2; }
fi
if [ -n "${disk}" ] && [ -z "${disk_format}" ]; then
   command -v qemu-img >/dev/null || { printf 'dm-qemu: qemu-img not installed (needed to auto-detect the disk format; or pass --disk-format)\n' >&2; exit 2; }
   disk_info="$(qemu-img info -- "${disk}")" \
      || { printf 'dm-qemu: qemu-img info failed for disk %s\n' "${disk}" >&2; exit 2; }
   disk_format="$(printf '%s\n' "${disk_info}" | sed -n -e 's/^file format: //p')"
   [ -n "${disk_format}" ] || { printf 'dm-qemu: could not auto-detect the format of %s; pass --disk-format\n' "${disk}" >&2; exit 2; }
fi
if [ -n "${screendump}" ]; then
   if ! command -v identify >/dev/null || ! command -v compare >/dev/null; then
      printf 'dm-qemu: ImageMagick (identify + compare) not installed (needed for --screendump)\n' >&2
      exit 2
   fi
fi

## Acceleration: 'auto' (default) uses KVM when the guest arch equals the host arch AND
## /dev/kvm is usable (GitHub CI and bare metal often expose it; a nested VM like this one may
## not), else TCG. --accel kvm forces KVM (errors if unavailable); --accel tcg forces
## emulation. KVM cannot cross-accelerate, so an arm64 guest on an amd64 host is always TCG.
kvm_usable='false'
if [ "${arch}" = "${host_arch}" ] && [ -e /dev/kvm ] && [ -w /dev/kvm ]; then
   kvm_usable='true'
fi
case "${accel}" in
   kvm)
      [ "${kvm_usable}" = 'true' ] || { printf 'dm-qemu: --accel kvm requested but KVM is unavailable (guest %s vs host %s, /dev/kvm)\n' "${arch}" "${host_arch}" >&2; exit 2; }
      accel_opts=(-enable-kvm -cpu host)
      printf 'dm-qemu: KVM acceleration (forced) (%s on %s)\n' "${arch}" "${host_arch}" >&2
      ;;
   tcg)
      accel_opts=(-cpu max)
      printf 'dm-qemu: TCG emulation (forced, slow)%s\n' "$([ "${fast}" = 'true' ] && printf ' (--fast)')" >&2
      ;;
   auto)
      if [ "${kvm_usable}" = 'true' ]; then
         accel_opts=(-enable-kvm -cpu host)
         printf 'dm-qemu: KVM acceleration (auto-detected) (%s on %s)\n' "${arch}" "${host_arch}" >&2
      else
         accel_opts=(-cpu max)
         if [ "${arch}" != "${host_arch}" ]; then
            printf 'dm-qemu: cross-arch (%s guest on %s host) -- TCG emulation (slow)%s\n' "${arch}" "${host_arch}" "$([ "${fast}" = 'true' ] && printf ', --fast')" >&2
         else
            printf 'dm-qemu: no usable /dev/kvm -- TCG emulation (slow)%s\n' "$([ "${fast}" = 'true' ] && printf ' (--fast: mitigations=off)')" >&2
         fi
      fi
      ;;
   *)
      printf 'dm-qemu: --accel must be auto|kvm|tcg: %s\n' "${accel}" >&2
      exit 2
      ;;
esac

## Screendump mode watches the guest FRAMEBUFFER over QMP (full firmware->GRUB->kernel chain,
## no serial, no image edits), so it needs a real VGA device and a headless display rather than
## the serial-only '-nographic -vga none'. It also needs a QMP socket to drive the captures;
## default one under the screendump dir when the caller did not pass --qmp.
if [ -n "${screendump}" ]; then
   mkdir --parents -- "${screendump}"
   qemu_opts=(-machine "${machine}" "${accel_opts[@]}" -m "${memory}" -smp "${smp}" -display none -vga std -no-reboot)
   [ -n "${qmp}" ] || qmp="${screendump}/qmp.sock"
else
   qemu_opts=(-machine "${machine}" "${accel_opts[@]}" -m "${memory}" -smp "${smp}" -nographic -no-reboot -vga none)
fi

## Give the guest a user-mode (NAT) NIC so the boot faithfully reproduces a real
## VM with network access -- systemcheck's --leak-tests, Tor bootstrap and
## sdwdate all need it, and without a backend the guest's eth0 stays DOWN.
## User-mode ('-nic user') needs no privileges and exposes no inbound port; it
## also disables qemu's implicit default NIC, so there is exactly one interface.
qemu_opts+=(-nic "user,model=virtio-net-pci")

## Boot media. An ISO is attached as an external USB mass-storage device -- a virtual USB stick --
## mirroring how users install: they write the ISO to a USB stick and boot it (isohybrid ISOs
## boot as a raw USB block device). This is arch-independent: unlike '-cdrom', which needs an IDE
## CD controller the arm64 'virt' board lacks, a USB xHCI controller works on amd64 and arm64
## alike. 'readonly=on' so qemu never writes back to the built ISO artifact (a live boot overlays
## its writes in RAM). A disk image is attached as a virtio-blk boot disk; '-snapshot' (added
## below) routes all guest writes to a throwaway overlay so the built artifact is never modified.
if [ -n "${iso}" ]; then
   media_opts=(
      -drive "if=none,id=usbstick,format=raw,readonly=on,file=${iso}"
      -device "qemu-xhci,id=xhci"
      -device "usb-storage,bus=xhci.0,drive=usbstick,removable=on"
   )
else
   media_opts=(-drive "if=virtio,format=${disk_format},file=${disk}")
   ## Non-destructive: every write lands in a temporary overlay, discarded on exit.
   qemu_opts+=(-snapshot)
fi

## Optional QMP control socket (unix, server, non-blocking): qemu listens, the driver connects
## after start. 'nowait' so qemu does not block on a QMP client before booting.
if [ -n "${qmp}" ]; then
   qemu_opts+=(-qmp "unix:${qmp},server,nowait")
fi

## Serial + verbose kernel parameters, shared by the SMBIOS-injected default boot and the
## --direct-kernel '-append'. Surface the EARLY boot on serial: without this the kernel
## self-decompressor and early init -- before the real 8250/PL011 tty driver registers -- are
## silent, which under TCG (no KVM) is minutes of silence that looks like a hang. earlyprintk
## (x86: the decompressor stub drives the UART directly) covers the decompression gap; earlycon
## covers early init until the real driver takes over; keep_bootcon makes the handoff seamless;
## ignore_loglevel + rd.info keep the kernel and the dracut initramfs chatty (and ignore_loglevel
## overrides the image's production 'quiet loglevel=0' when these params are APPENDED via SMBIOS).
## Arch-gated: the x86 'earlyprintk=serial,ttyS0' form is invalid on arm64 (PL011). printk.time=1
## timestamps every line so a long gap is attributable to its phase; initcall_debug names a
## stalled initcall. Both arch-independent.
case "${serial_console}" in
   ttyS0*)
      early_console='earlyprintk=serial,ttyS0,115200 earlycon=ttyS0,115200 keep_bootcon ignore_loglevel rd.info'
      ;;
   *)
      early_console='earlycon keep_bootcon ignore_loglevel rd.info'
      ;;
esac
serial_verbose_params="console=${serial_console} ${early_console} printk.time=1 initcall_debug"

if [ "${direct_kernel}" = 'true' ]; then
   ## Extract the kernel, initrd and grub.cfg from the ISO, derive the chosen entry's cmdline,
   ## strip the silencers, and direct-boot. The ISO stays attached (USB stick) as the live medium.
   work_dir="$(mktemp --directory)"
   ## In --emit-argv mode the extracted kernel/initrd must OUTLIVE this process (the external
   ## driver spawns qemu against them), so the caller owns the workdir -- do not auto-clean it.
   if [ "${emit_argv}" != 'true' ]; then
      trap dm_qemu_cleanup_workdir EXIT
   fi

   xorriso -osirrox on -indev "${iso}" -extract /boot/grub/grub.cfg "${work_dir}/grub.cfg" >/dev/null 2>&1 \
      || { printf 'dm-qemu: could not extract /boot/grub/grub.cfg from the ISO\n' >&2; exit 2; }

   ## Locate the live kernel + initrd inside the ISO (version-independent).
   kernel_iso_path="$(xorriso -indev "${iso}" -find /live -name 'vmlinuz-*' -type f 2>/dev/null | tr -d "'" | grep -m1 -E '/live/vmlinuz-' || true)"
   initrd_iso_path="$(xorriso -indev "${iso}" -find /live -name 'initrd.img-*' -type f 2>/dev/null | tr -d "'" | grep -m1 -E '/live/initrd.img-' || true)"
   if [ -z "${kernel_iso_path}" ] || [ -z "${initrd_iso_path}" ]; then
      printf 'dm-qemu: could not locate /live/vmlinuz-* and /live/initrd.img-* in the ISO\n' >&2
      exit 2
   fi
   xorriso -osirrox on -indev "${iso}" \
      -extract "${kernel_iso_path}" "${work_dir}/vmlinuz" \
      -extract "${initrd_iso_path}" "${work_dir}/initrd.img" >/dev/null 2>&1 \
      || { printf 'dm-qemu: kernel/initrd extraction failed\n' >&2; exit 2; }

   ## Pick the menu entry whose cmdline to reuse. The USER entry is the first 'linux' line; the
   ## others are matched by their distinguishing boot-role token so the choice is unambiguous.
   entry_grep='boot=live'
   case "${entry}" in
      user)
         entry_grep='rd.emergency=halt rd.shell=0 iso-scan'
         ;;
      sysmaint)
         entry_grep='boot-role=sysmaint'
         ;;
      unrestricted)
         entry_grep='boot-role=unrestricted-admin'
         ;;
      *)
         printf 'dm-qemu: --entry must be user|sysmaint|unrestricted: %s\n' "${entry}" >&2
         exit 2
         ;;
   esac
   linux_line="$(grep -E '^\s*linux\s+/live/vmlinuz' "${work_dir}/grub.cfg" | grep -m1 -F -- "${entry_grep}" || true)"
   [ -n "${linux_line}" ] || linux_line="$(grep -m1 -E '^\s*linux\s+/live/vmlinuz' "${work_dir}/grub.cfg" || true)"
   [ -n "${linux_line}" ] || { printf 'dm-qemu: no live "linux" entry found in grub.cfg\n' >&2; exit 2; }

   ## Everything after the kernel path is the cmdline. Strip the silencers (debug-misc parity),
   ## the GRUB-only 'iso-scan/filename=${iso_path}' variable, and the halt-on-initrd-failure so a
   ## failed boot drops to a shell (visible) instead of a silent halt.
   cmdline="$(printf '%s' "${linux_line}" | sed -E 's#^\s*linux\s+/live/vmlinuz[^ ]*\s+##')"
   cmdline="$(printf '%s' "${cmdline}" | sed -E 's/\bquiet\b//g; s/\bloglevel=0\b//g; s/\bsplash\b//g; s#iso-scan/filename=\$\{iso_path\}##g; s/\brd.emergency=halt\b//g; s/\brd.shell=0\b/rd.shell=1/g')"
   if [ "${fast}" = 'true' ]; then
      cmdline="${cmdline} mitigations=off"
   fi
   ## Ensure the arch-correct serial console + early-console + debug params are present even if the
   ## entry somehow lacked them (or carried an x86 ttyS0 on an arm64 image); append the extra cmdline.
   full_append="${serial_verbose_params} ${cmdline} systemd.log_level=info ${extra_append}"

   printf 'dm-qemu: direct-kernel boot of %s (entry=%s, fast=%s, timeout=%ss)\n' "${kernel_iso_path##*/}" "${entry}" "${fast}" "${timeout_secs}" >&2
   qemu_opts+=(-kernel "${work_dir}/vmlinuz" -initrd "${work_dir}/initrd.img" -append "${full_append}" "${media_opts[@]}")
else
   ## Firmware boot (the default). On arm64 there is no BIOS, so 'virt' needs UEFI firmware to run
   ## the artifact's GRUB-efi; locate an edk2 build or fail with a clear hint. x86 uses SeaBIOS
   ## unless --firmware selects OVMF.
   if [ "${guest_machine}" = 'aarch64' ]; then
      arm_uefi=''
      for arm_uefi_candidate in \
         /usr/share/AAVMF/AAVMF_CODE.fd \
         /usr/share/qemu-efi-aarch64/QEMU_EFI.fd \
         /usr/share/edk2/aarch64/QEMU_EFI.fd; do
         if [ -r "${arm_uefi_candidate}" ]; then
            arm_uefi="${arm_uefi_candidate}"
            break
         fi
      done
      [ -n "${arm_uefi}" ] || { printf 'dm-qemu: arm64 boot needs edk2 UEFI firmware (install qemu-efi-aarch64)\n' >&2; exit 2; }
      qemu_opts+=(-bios "${arm_uefi}")
   elif [ "${guest_machine}" = 'x86_64' ] && [ "${firmware}" != 'bios' ]; then
      ## x86 EFI boot via OVMF pflash (SeaBIOS is the default BIOS path). efi-secureboot uses the
      ## secboot firmware + Microsoft-key vars (which validate Debian's MS-signed shim) plus the
      ## flash 'secure' property; SMM is set on the machine above.
      case "${firmware}" in
         efi)
            ovmf_code='/usr/share/OVMF/OVMF_CODE_4M.fd'
            ovmf_vars_src='/usr/share/OVMF/OVMF_VARS_4M.fd'
            ;;
         efi-secureboot)
            ovmf_code='/usr/share/OVMF/OVMF_CODE_4M.secboot.fd'
            ovmf_vars_src='/usr/share/OVMF/OVMF_VARS_4M.ms.fd'
            qemu_opts+=(-global 'driver=cfi.pflash01,property=secure,value=on')
            ;;
      esac
      if [ ! -r "${ovmf_code}" ] || [ ! -r "${ovmf_vars_src}" ]; then
         printf 'dm-qemu: OVMF firmware not found (install the ovmf package) for --firmware %s\n' "${firmware}" >&2
         exit 2
      fi
      ## Writable per-boot copy of the vars flash in an auto-cleaned workdir (--emit-argv leaves
      ## ownership to the caller, mirroring the direct-kernel path). Not reused when a direct-kernel
      ## workdir already exists (the two boot paths are mutually exclusive).
      work_dir="$(mktemp --directory)"
      if [ "${emit_argv}" != 'true' ]; then
         trap dm_qemu_cleanup_workdir EXIT
      fi
      cp -- "${ovmf_vars_src}" "${work_dir}/OVMF_VARS.fd"
      qemu_opts+=(
         -drive "if=pflash,format=raw,unit=0,readonly=on,file=${ovmf_code}"
         -drive "if=pflash,format=raw,unit=1,file=${work_dir}/OVMF_VARS.fd"
      )
   fi
   printf 'dm-qemu: firmware boot of %s over serial (firmware=%s; verbose+serial params injected via SMBIOS)\n' "${image##*/}" "${firmware}" >&2
   ## Boot from the emulated media (no '-boot d': there is no CD; firmware picks the bootable
   ## USB stick / virtio disk -- SeaBIOS on x86, edk2 on arm64).
   qemu_opts+=("${media_opts[@]}")
   ## SMBIOS cmdline injection through the FULL firmware -> GRUB -> kernel chain (which qemu
   ## '-append' cannot reach -- that only works with '-kernel' direct boot). A cooperating grub.cfg
   ## reader in the image (insmod smbios; smbios --type 1 --get-string 7) picks up the 'dm-cmdline='
   ## sentinel from the SMBIOS Type 1 system serial number (offset 7) and appends the remainder to
   ## the kernel line. Type 1 offset 7 is a real string-reference field GRUB can read; Type 11 OEM
   ## strings have no such field in the formatted area. SMBIOS is supplied by SeaBIOS (BIOS) and
   ## OVMF (EFI) alike; the reader's smbios module is in Debian's SIGNED grub, so this works on
   ## BIOS, EFI, and EFI+Secure-Boot -- GRUB lockdown does not block the smbios read or the append.
   ## Commas in the payload are doubled per qemu's value escaping. On the default serial boot the
   ## payload is the verbose+serial params (+ --smbios-append); under --screendump it is only
   ## --smbios-append (the framebuffer test wants the image's normal graphical boot). Only
   ## meaningful on this full-chain path, not --direct-kernel (direct boot).
   if [ -n "${screendump}" ]; then
      smbios_payload="${smbios_append}"
   else
      if [ "${test_console}" = 'true' ]; then
         ## Reliable automation channel: bind a login-free ROOT shell to the serial
         ## console via systemd's debug-shell, and MASK the login getty so it -- not
         ## an interactive user zsh whose line editor (ZLE) corrupts programmatic
         ## input -- owns the tty. Quiet the kernel console (loglevel=3) so command
         ## output reads cleanly. Consumed by dm-image-test.
         serial_tty="${serial_console%%,*}"
         smbios_payload="console=${serial_console} loglevel=3 systemd.debug_shell=${serial_tty} systemd.mask=serial-getty@${serial_tty}.service"
      else
         smbios_payload="${serial_verbose_params} systemd.log_level=info"
      fi
      if [ "${fast}" = 'true' ]; then
         smbios_payload="${smbios_payload} mitigations=off"
      fi
      if [ -n "${smbios_append}" ]; then
         smbios_payload="${smbios_payload} ${smbios_append}"
      fi
   fi
   if [ -n "${smbios_payload}" ]; then
      qemu_opts+=(-smbios "type=1,serial=dm-cmdline=${smbios_payload//,/,,}")
   fi
fi

if [ "${emit_argv}" = 'true' ]; then
   ## Print the qemu binary + argv, one token per line, for an external driver to read into a
   ## list and spawn (e.g. Python pexpect). One-token-per-line is unambiguous even though the
   ## '-append' value contains spaces: each array element is exactly one line, and no element
   ## contains a newline. The caller adds its own serial wiring ('-serial mon:stdio' etc.).
   if [ "${direct_kernel}" = 'true' ]; then
      printf 'dm-qemu: emit-argv workdir (caller owns cleanup): %s\n' "${work_dir}" >&2
   fi
   printf '%s\n' "${qemu_bin}"
   printf '%s\n' "${qemu_opts[@]}"
   exit 0
fi

: > "${serial_log}"
## The guest serial console (the ACTUAL boot output) is redirected to the serial-log FILE
## below, NOT to this process's stdout/stderr -- which carry only this start line and the
## end/verdict line. Point the operator at the file up front so a detached/backgrounded run
## is watched by tailing the right thing (mistaking dm-qemu's quiet stderr for "stuck" is an
## easy trap): tail -f "${serial_log}".
printf 'dm-qemu: booting; serial console -> %s\n' "${serial_log}" >&2
printf 'dm-qemu: watch the boot LIVE with: tail -f %s  (this stderr shows only start + verdict)\n' "${serial_log}" >&2
qemu_rc=0

if [ -n "${screendump}" ]; then
   ## Full-chain framebuffer test: start qemu in the BACKGROUND (its own console still lands in
   ## the serial log for reference) and let the QMP watcher capture + judge the screen. The
   ## watcher powers the guest down when done; we backstop with an explicit kill of that PID.
   ## A stale QMP socket from a prior run would make qemu's bind() fail ("address already in
   ## use"), so remove it first (qemu recreates it).
   rm --force -- "${qmp}"
   ## Hard time backstop: bound qemu with 'timeout' (slack over the watcher's own --timeout) so
   ## a wedged watcher can never leave qemu running forever (the serial path is bounded too).
   timeout "$(( timeout_secs + 120 ))" "${qemu_bin}" "${qemu_opts[@]}" < /dev/null > "${serial_log}" 2>&1 &
   qemu_pid="$!"
   self_dir="$(dirname -- "$(readlink --canonicalize -- "$0")")"
   watch_rc=0
   "${self_dir}/dm-qemu-screendump-watch" \
      --qmp "${qmp}" --outdir "${screendump}" --timeout "${timeout_secs}" || watch_rc="$?"
   ## Backstop-kill the backgrounded qemu. The trailing '|| true' is load-bearing: if the guest
   ## finished powering off during the sleep, the second 'kill' fails, and as the last command of
   ## this 'if' body that non-zero would trip 'set -e' and abort BEFORE the verdict below -- on
   ## the common SUCCESS path.
   if kill -0 "${qemu_pid}" 2>/dev/null; then
      sleep 5
      { kill -0 "${qemu_pid}" 2>/dev/null && kill "${qemu_pid}" 2>/dev/null; } || true
   fi
   wait "${qemu_pid}" 2>/dev/null || true
   ## Corroborate with the serial log: screendump mode still captures serial, so a login/systemd
   ## marker means the guest DID boot even when the framebuffer heuristic did not latch (e.g. an
   ## animated greeter). Present only when the image exposes a serial console.
   reached="$(grep -ioE 'login:|Reached target|systemd\[1\]|Welcome to' "${serial_log}" 2>/dev/null | sort -u | tr '\n' ' ' || true)"
   case "${watch_rc}" in
      0)
         printf 'dm-qemu: PASS -- guest reached a rendered greeter/desktop (frames in %s)\n' "${screendump}" >&2
         exit 0
         ;;
      5)
         if [ -n "${reached}" ]; then
            printf 'dm-qemu: PASS -- serial log confirms boot (%s); framebuffer heuristic did not latch (frames in %s)\n' "${reached}" "${screendump}" >&2
            exit 0
         fi
         printf 'dm-qemu: PARTIAL -- no greeter/desktop within %ss and no serial boot marker (frames in %s)\n' "${timeout_secs}" "${screendump}" >&2
         exit 5
         ;;
      *)
         printf 'dm-qemu: screendump watcher error (rc=%s); frames in %s\n' "${watch_rc}" "${screendump}" >&2
         exit 2
         ;;
   esac
fi

timeout "${timeout_secs}" "${qemu_bin}" "${qemu_opts[@]}" < /dev/null > "${serial_log}" 2>&1 || qemu_rc="$?"

## '|| true': a fully-failed boot produces none of the markers, so grep exits 1, which under
## 'set -e -o pipefail' would abort the assignment here and bypass the FAIL / exit-5 reporting below.
reached="$(grep -ioE 'login:|Reached target|systemd\[1\]|Welcome to' "${serial_log}" 2>/dev/null | sort -u | tr '\n' ' ' || true)"
printf 'dm-qemu: boot ended (qemu rc=%s); serial=%s bytes; reached: %s\n' "${qemu_rc}" "$(wc -c < "${serial_log}" 2>/dev/null || printf 0)" "${reached:-<none>}" >&2

if printf '%s' "${reached}" | grep -qiE 'login:'; then
   printf 'dm-qemu: PASS -- reached a login prompt\n' >&2
   exit 0
fi
## 'Welcome to ...' is emitted by systemd at the START of userspace boot, long before a login
## prompt, so it proves "kernel + systemd started" (PARTIAL), NOT "reached login" -- a guest that
## prints it and then stalls before login must not read as PASS.
if printf '%s' "${reached}" | grep -qiE 'Reached target|systemd\[1\]|Welcome to'; then
   printf 'dm-qemu: PARTIAL -- kernel + systemd booted but no login prompt within %ss\n' "${timeout_secs}" >&2
   exit 5
fi
printf 'dm-qemu: FAIL -- kernel produced no systemd/login markers (see %s)\n' "${serial_log}" >&2
exit 5
