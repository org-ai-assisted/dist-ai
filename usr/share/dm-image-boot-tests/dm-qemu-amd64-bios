## AI-Assisted

## Thin wrapper: headless boot-test an amd64 VM disk image through SeaBIOS via dm-qemu.
## First argument is the disk image (qcow2/raw/vdi/vmdk); any further arguments are forwarded
## to dm-qemu unchanged (e.g. --timeout, --screendump, --disk-format).

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

[ "$#" -ge 1 ] || { printf '%s\n' "Usage: dm-qemu-amd64-bios DISK_IMAGE [dm-qemu options...]" >&2; exit 2; }

dm_qemu_wrapper_dir="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
disk_image="${1}"
shift

"${dm_qemu_wrapper_dir}/dm-qemu" --disk "${disk_image}" --arch amd64 --firmware bios "$@"
