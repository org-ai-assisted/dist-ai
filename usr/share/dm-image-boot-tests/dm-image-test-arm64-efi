## AI-Assisted

## Thin wrapper: boot-test an arm64 disk image through edk2 UEFI via dm-image-test (boot + login + functional checks).
## First argument is the disk image (qcow2/raw/vdi/vmdk); any further arguments are
## forwarded to dm-image-test unchanged (e.g. --session, --login-pass, --run, --timeout).

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

[ "$#" -ge 1 ] || { printf '%s\n' "Usage: dm-image-test-arm64-efi DISK_IMAGE [dm-image-test options...]" >&2; exit 2; }

dm_image_test_wrapper_dir="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
disk_image="${1}"
shift

"${dm_image_test_wrapper_dir}/dm-image-test" --disk "${disk_image}" --arch arm64 "$@"
