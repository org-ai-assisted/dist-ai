"""Boot an image in qemu, log in over the serial console, run functional checks
(by default 'systemcheck --leak-tests') and report a single pass/fail exit code.

This is the functional layer on top of dm-qemu: dm-qemu owns qemu, firmware,
Secure Boot and the SMBIOS kernel-cmdline injection; dm-image-test only drives
the login conversation and aggregates the checks' exit codes. It obtains the
exact qemu argv from 'dm-qemu --emit-argv' (which builds but does not boot), then
spawns it under pexpect so it can interact with the guest.

Session selection (user vs sysmaint) is done through dm-qemu's --smbios-append,
which injects a kernel cmdline the in-image GRUB SMBIOS reader appends -- no image
edit, works on BIOS, EFI and EFI+Secure Boot alike.

Exit codes mirror dm-qemu's triad so CI reads one consistent signal:
  0  every check returned its expected exit code (PASS)
  5  booted but a check failed, or the login prompt was never reached (FAIL)
  2  setup / usage error (bad flag, dm-qemu missing, qemu argv error)
"""

import argparse
import os
import shlex
import subprocess
import sys

PASS = 0
FAIL = 5
SETUP = 2

## Map --session to the kernel cmdline the sysmaint boot entry uses (see
## user-sysmaint-split grub.d_10_10_linux_sysmaint). 'user' is the default
## session and needs no injection.
SESSION_CMDLINE = {
    "user": "",
    "sysmaint": "boot-role=sysmaint systemd.unit=sysmaint-boot.target",
}


def die_setup(message):
    print("dm-image-test: %s" % message, file=sys.stderr)
    sys.exit(SETUP)


def parse_args():
    parser = argparse.ArgumentParser(
        prog="dm-image-test",
        description="Boot an image, log in and run functional checks.",
    )
    source = parser.add_mutually_exclusive_group(required=True)
    source.add_argument("--disk", help="disk image to boot (qcow2/raw/vdi/vmdk)")
    source.add_argument("--iso", help="live ISO to boot")
    parser.add_argument("--arch", default="", help="amd64|arm64 (default: host)")
    parser.add_argument(
        "--firmware", default="",
        help="bios|efi|efi-secureboot (x86; forwarded to dm-qemu)",
    )
    parser.add_argument(
        "--session", choices=sorted(SESSION_CMDLINE), default="user",
        help="which session to boot into (default: user)",
    )
    parser.add_argument("--login-user", default="user", help="serial login account")
    parser.add_argument(
        "--login-pass", default="",
        help="serial login password; empty means no password is expected",
    )
    parser.add_argument(
        "--run", action="append", metavar="CMD", default=None,
        help="command to run after login (repeatable). "
        "Default: 'systemcheck --cli --leak-tests --verbose'.",
    )
    parser.add_argument(
        "--expect-rc", type=int, default=0,
        help="exit code every --run command must return (default: 0)",
    )
    parser.add_argument("--timeout", type=int, default=1800, help="overall timeout (s)")
    parser.add_argument(
        "--smbios-append", default="",
        help="extra kernel cmdline to inject (merged with --session)",
    )
    parser.add_argument("--serial-log", default="", help="write the serial log here")
    parser.add_argument(
        "--dm-qemu", default="dm-qemu",
        help="path to the dm-qemu executable (default: PATH lookup)",
    )
    ## Any tokens after '--' are passed straight to dm-qemu (e.g. --memory, --smp).
    parser.add_argument("dm_qemu_args", nargs=argparse.REMAINDER)
    return parser.parse_args()


def build_qemu_argv(args):
    """Return the qemu argv by asking dm-qemu to emit it (build-only, no boot)."""
    cmd = [args.dm_qemu]
    if args.disk:
        cmd += ["--disk", args.disk]
    else:
        cmd += ["--iso", args.iso]
    if args.arch:
        cmd += ["--arch", args.arch]
    if args.firmware:
        cmd += ["--firmware", args.firmware]

    ## Reliable automation channel: a login-free ROOT shell on the serial console
    ## (systemd debug-shell + masked login getty), so we never drive the image's
    ## interactive user zsh (whose line editor corrupts programmatic input).
    cmd += ["--test-console"]

    ## Merge the session cmdline with any caller-supplied --smbios-append.
    append_parts = []
    session_cmdline = SESSION_CMDLINE[args.session]
    if session_cmdline:
        append_parts.append(session_cmdline)
    if args.smbios_append:
        append_parts.append(args.smbios_append)
    if append_parts:
        cmd += ["--smbios-append", " ".join(append_parts)]

    ## Drop the leading '--' argparse leaves in REMAINDER.
    extra = args.dm_qemu_args
    if extra and extra[0] == "--":
        extra = extra[1:]
    cmd += extra
    cmd += ["--emit-argv"]

    try:
        result = subprocess.run(
            cmd, check=True, capture_output=True, text=True
        )
    except FileNotFoundError:
        die_setup("dm-qemu not found: %s" % args.dm_qemu)
    except subprocess.CalledProcessError as exc:
        sys.stderr.write(exc.stderr or "")
        die_setup("dm-qemu --emit-argv failed (exit %s)" % exc.returncode)

    ## dm-qemu --emit-argv prints one token per line.
    argv = [line for line in result.stdout.splitlines() if line != ""]
    if not argv:
        die_setup("dm-qemu --emit-argv produced no qemu argv")

    ## dm-qemu leaves any per-boot workdir (kernel/initrd extraction or the EFI
    ## OVMF_VARS copy) for us to remove once qemu has exited; it reports the path
    ## on stderr. Capture it so we clean up instead of leaking under /tmp.
    workdir = None
    marker = "dm-qemu: emit-argv workdir (caller owns cleanup): "
    for line in (result.stderr or "").splitlines():
        if line.startswith(marker):
            workdir = line[len(marker):].strip()
    return argv, workdir


def run_checks(child, args, log):
    """Run the checks over the login-free ROOT serial shell that dm-qemu
    --test-console binds to the console (systemd debug-shell, login getty masked).

    This deliberately bypasses the image's interactive user zsh, whose line editor
    corrupts programmatically-sent input (mangles "$?", swallows 'exec'). We drive
    a plain root bash, match on our OWN accumulated buffer (read_nonblocking is more
    reliable than pexpect.expect on the noisy console), and read each command's exit
    code from a unique sentinel. Commands run as root by default, or as --login-user
    via a NON-interactive 'su -' (never the user's interactive shell).
    """
    import re
    import shlex
    import time
    import pexpect  # noqa: E402  (lazy so --help works without it)

    accum = [""]

    ## Single overall deadline so --timeout bounds the WHOLE conversation, not
    ## each phase independently (a short --timeout must not still run ~10 min
    ## through the 60-iteration probe plus a full per-phase wait each).
    overall_deadline = time.time() + args.timeout

    def wait_for(needle, timeout, regex=False):
        """Read until 'needle' appears in the accumulated output, or the phase
        timeout or the overall deadline, whichever is first. Returns the re.Match
        (regex) / True (substring) / None on timeout|EOF."""
        deadline = min(time.time() + timeout, overall_deadline)
        pattern = re.compile(needle) if regex else None
        while time.time() < deadline:
            try:
                accum[0] += child.read_nonblocking(size=4096, timeout=1)
            except pexpect.TIMEOUT:
                pass
            except pexpect.EOF:
                return None
            if regex:
                match = pattern.search(accum[0])
                if match:
                    return match
            elif needle in accum[0]:
                return True
        return None

    ## 1) Wait for the login-free root shell. systemd's debug-shell binds it to the
    ##    console mid-boot; probe with a split-token printf (only the shell's real
    ##    OUTPUT of the joined token matches, not the command echo) until it answers.
    token = "DMRDY%d" % os.getpid()
    needle = "DM<>%s<>" % token
    shell_live = False
    for _ in range(60):
        if time.time() >= overall_deadline:
            break
        child.sendline("printf 'DM<>%%s<>\\n' %s" % token)
        if wait_for(needle, 10):
            shell_live = True
            break
    if not shell_live:
        log("dm-image-test: root serial shell (--test-console) never came up")
        return FAIL

    ## 2) Boot barrier: wait until the system finishes coming up so checks see a
    ##    complete environment. is-system-running --wait blocks until
    ##    running/degraded; its status is not the verdict, just the barrier.
    boot_done = "DMBOOT%d" % os.getpid()
    child.sendline("systemctl is-system-running --wait >/dev/null 2>&1; printf '%s\\n'"
                   % boot_done)
    wait_for(boot_done, args.timeout)

    ## 3) Run each check; read its exit code from a unique sentinel (the echoed
    ##    command carries a literal '%s', so only the real output matches). Root by
    ##    default; --login-user (!= root) runs the command as that user via a
    ##    non-interactive 'su -', never touching the user's interactive shell.
    commands = args.run
    if commands is None:
        commands = ["systemcheck --cli --leak-tests --verbose"]
    sentinel = "DMRC%d" % os.getpid()
    rc_re = r"%s:(-?\d+):%s" % (sentinel, sentinel)
    overall = PASS
    for command in commands:
        if args.login_user and args.login_user != "root":
            payload = "su - %s -c %s" % (shlex.quote(args.login_user),
                                         shlex.quote(command))
        else:
            payload = command
        child.sendline("%s; printf '%s:%%s:%s\\n' \"$?\""
                       % (payload, sentinel, sentinel))
        match = wait_for(rc_re, args.timeout, regex=True)
        if match is None:
            log("dm-image-test: command timed out or guest died: %s" % command)
            return FAIL
        rc = int(match.group(1))
        ## Drop consumed output so the next command's sentinel is unambiguous.
        accum[0] = accum[0][match.end():]
        if rc == args.expect_rc:
            log("dm-image-test: OK   (rc=%s) %s" % (rc, command))
        else:
            log("dm-image-test: FAIL (rc=%s, want %s) %s"
                % (rc, args.expect_rc, command))
            overall = FAIL

    ## 4) Power off (best-effort; the verdict is already decided). Bound the wait
    ##    by the overall deadline so --timeout covers shutdown too; main's finally
    ##    force-terminates qemu regardless.
    child.sendline("poweroff")
    shutdown_wait = max(1, min(120, overall_deadline - time.time()))
    try:
        child.expect(pexpect.EOF, timeout=shutdown_wait)
    except (pexpect.TIMEOUT, pexpect.EOF):
        pass
    return overall


def main():
    args = parse_args()

    try:
        import pexpect
    except ImportError:
        die_setup("python3-pexpect is required (apt-get install python3-pexpect)")

    qemu_argv, qemu_workdir = build_qemu_argv(args)

    def log(message):
        print(message, file=sys.stderr)

    ## Wrap ALL post-build setup so the caller-owned workdir dm-qemu left for us
    ## (EFI OVMF_VARS copy or kernel/initrd extraction) is removed even if the
    ## serial-log open or pexpect.spawn raises -- else it leaks under /tmp.
    child = None
    try:
        log_file = None
        if args.serial_log:
            try:
                log_file = open(args.serial_log, "wb")
            except OSError as exc:
                die_setup("cannot open --serial-log %s: %s" % (args.serial_log, exc))

        print("dm-image-test: spawning: %s"
              % " ".join(shlex.quote(token) for token in qemu_argv), file=sys.stderr)
        child = pexpect.spawn(
            qemu_argv[0], qemu_argv[1:], timeout=args.timeout, encoding="utf-8"
        )
        ## Pace input: the guest's zsh line editor (ZLE) mangles rapidly-sent lines
        ## (auto-suggest + cursor redraws corrupt e.g. "$?", and a queued 'exec'
        ## never submits). A small pre-send delay lets each line be read and run
        ## before the next, so 'exec bash' actually takes and metacharacters survive.
        child.delaybeforesend = 0.4
        if log_file is not None:
            ## pexpect writes str; wrap the binary log file.
            import io
            child.logfile_read = io.TextIOWrapper(log_file, write_through=True)

        verdict = run_checks(child, args, log)
    finally:
        if child is not None and child.isalive():
            child.terminate(force=True)
        if qemu_workdir:
            import shutil
            shutil.rmtree(qemu_workdir, ignore_errors=True)

    sys.exit(verdict)


if __name__ == "__main__":
    main()
