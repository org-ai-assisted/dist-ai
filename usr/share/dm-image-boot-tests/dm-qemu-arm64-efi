## AI-Assisted

## Thin wrapper: headless boot-test an arm64 VM disk image via dm-qemu. arm64 has no BIOS, so the
## 'virt' board always boots through edk2 UEFI firmware (needs the 'qemu-efi-aarch64' package);
## no --firmware flag is passed (dm-qemu rejects efi/efi-secureboot on arm64 -- it is UEFI already).
## First argument is the disk image (qcow2/raw/vdi/vmdk); any further arguments are forwarded to
## dm-qemu unchanged (e.g. --timeout, --screendump, --disk-format).

set -o errexit
set -o nounset
set -o pipefail
set -o errtrace
shopt -s inherit_errexit
shopt -s shift_verbose

[ "$#" -ge 1 ] || { printf '%s\n' "Usage: dm-qemu-arm64-efi DISK_IMAGE [dm-qemu options...]" >&2; exit 2; }

dm_qemu_wrapper_dir="$(dirname -- "$(readlink -f -- "${BASH_SOURCE[0]}")")"
disk_image="${1}"
shift

"${dm_qemu_wrapper_dir}/dm-qemu" --disk "${disk_image}" --arch arm64 "$@"
